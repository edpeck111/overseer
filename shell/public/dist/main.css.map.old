{
  "version": 3,
  "sources": ["../../src/styles/tokens.css", "../../src/styles/base.css", "../../src/chrome/statusbar.css", "../../src/chrome/breadcrumb.css", "../../src/chrome/hotkey_bar.css", "../../src/palette/palette.css", "../../src/modules/home.css"],
  "sourcesContent": ["/* ======================================================================\n   OVERSEER v3 \u2014 design tokens\n   Lifted verbatim from docs/00-VISUAL-REFERENCE.html (canonical).\n   When this file and the visual reference disagree, the file wins.\n   ====================================================================== */\n\n:root {\n  /* Backgrounds ------------------------------------------------------ */\n  --bg-deep:        #050807;   /* terminal background */\n  --bg-panel:       #0a1410;   /* panel fill */\n  --bg-panel-hi:    #0f1d17;   /* panel hover/active */\n  --bg-strip:       #06120c;   /* status strip, hotkey bar */\n\n  /* Rules / borders -------------------------------------------------- */\n  --rule-dim:       #133021;\n  --rule:           #1f5538;\n  --rule-bright:    #2d7a4e;\n\n  /* Phosphor green (primary) ---------------------------------------- */\n  --fg-dim:         #1d8c4a;\n  --fg:             #2cc26a;\n  --fg-bright:      #5fff9b;\n  --fg-glow:        #b8ffd2;\n\n  /* Accents ---------------------------------------------------------- */\n  --amber:          #ffb849;   /* headers, brand, attention */\n  --amber-bright:   #ffd27a;\n  --red:            #ff4747;   /* danger only */\n  --red-bright:     #ff8585;\n  --cyan:           #4adfff;   /* network, signed/verified */\n  --cyan-bright:    #8ff0ff;\n  --magenta:        #ff5fb8;   /* SIGNAL module */\n  --violet:         #b58cff;   /* admin overlays, easter eggs */\n  --paper:          #d8e8d8;   /* high-contrast fallback */\n\n  /* Typography ------------------------------------------------------- */\n  --char-w:         clamp(7px, 1.45vw, 11px);\n  --line-h:         1.55;\n\n  /* Glow ------------------------------------------------------------- */\n  --glow-soft:      0 0 6px rgba(95,255,155,0.25), 0 0 14px rgba(95,255,155,0.08);\n  --glow-strong:    0 0 4px rgba(184,255,210,0.55), 0 0 12px rgba(95,255,155,0.35);\n\n  /* Breakpoints (informational; CSS uses [data-mode] rather than @media) */\n  --bp-tablet:      720px;\n  --bp-desktop:     1100px;\n}\n", "/* Base atmosphere \u2014 body background, scanlines, vignette, terminal\n * frame. Per P7: box-drawing only, no rounded corners, no gradients\n * except the soft radials that are part of the \"salvaged ARM in a\n * metal case\" CRT feel. Per P10: degrades gracefully if any of these\n * fail to render (the underlying content is still legible). */\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml, body {\n  background: var(--bg-deep);\n  color: var(--fg);\n  font-family: 'JetBrains Mono', ui-monospace, 'Cascadia Mono', monospace;\n  font-size: var(--char-w);\n  line-height: var(--line-h);\n  letter-spacing: 0.02em;\n  min-height: 100vh;\n  overflow-x: hidden;\n}\n\nbody {\n  background:\n    radial-gradient(ellipse at 50% 20%, rgba(45,122,78,0.10), transparent 60%),\n    radial-gradient(ellipse at 50% 90%, rgba(20,80,50,0.08), transparent 70%),\n    var(--bg-deep);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 0;\n}\n\n/* CRT scanline overlay --------------------------------------------- */\nbody::before {\n  content: '';\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  background: repeating-linear-gradient(\n    to bottom,\n    rgba(0,0,0,0)    0px,\n    rgba(0,0,0,0)    2px,\n    rgba(0,0,0,0.18) 3px,\n    rgba(0,0,0,0)    4px\n  );\n  z-index: 999;\n  opacity: 0.55;\n  mix-blend-mode: multiply;\n}\n\n/* Vignette --------------------------------------------------------- */\nbody::after {\n  content: '';\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  background: radial-gradient(\n    ellipse at center,\n    transparent 60%,\n    rgba(0,0,0,0.45) 100%\n  );\n  z-index: 998;\n}\n\n/* Reduced motion / :crt off knobs (Sprint 15 wires runtime toggles) */\n:root[data-crt=\"off\"] body::before,\n:root[data-crt=\"off\"] body::after { display: none; }\n@media (prefers-reduced-motion: reduce) {\n  *, *::before, *::after { animation-duration: 0.01ms !important; }\n}\n\n/* Terminal frame --------------------------------------------------- */\n.terminal {\n  background: var(--bg-deep);\n  border: 1px solid var(--rule-bright);\n  box-shadow:\n    0 0 0 1px var(--bg-deep) inset,\n    0 0 24px rgba(45,122,78,0.18),\n    0 0 60px rgba(20,80,50,0.10);\n  width: 100%;\n  position: relative;\n  overflow: hidden;\n}\n.terminal[data-mode=\"phone\"]   { max-width: 720px; }\n.terminal[data-mode=\"tablet\"]  { max-width: 1100px; }\n.terminal[data-mode=\"desktop\"] { max-width: 1380px; }\n\n.term-glow {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  background: radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(0,0,0,0.6) 100%);\n  z-index: 1;\n}\n\n/* Cursor blink (used by prompt + palette) -------------------------- */\n.cursor {\n  display: inline-block;\n  width: 0.6em;\n  height: 1em;\n  background: var(--fg-bright);\n  margin-left: 1px;\n  vertical-align: text-bottom;\n  animation: cursorblink 1.05s steps(2,end) infinite;\n}\n@keyframes cursorblink { 50% { background: transparent; } }\n\n/* Status pulse for alerts ------------------------------------------ */\n@keyframes blink { 50% { opacity: 0.35; } }\n", "/* Status strip \u2014 top of the terminal frame, always visible. */\n\n.statusbar {\n  display: flex;\n  align-items: center;\n  gap: 0;\n  background: var(--bg-strip);\n  border-bottom: 1px solid var(--rule-bright);\n  padding: 6px 10px;\n  font-size: 0.95em;\n  white-space: nowrap;\n  overflow: hidden;\n}\n.statusbar .seg {\n  padding: 0 10px;\n  border-right: 1px dashed var(--rule);\n  color: var(--fg);\n  display: flex;\n  gap: 6px;\n  align-items: center;\n}\n.statusbar .seg:first-child { padding-left: 0; }\n.statusbar .seg:last-child  { border-right: 0; padding-right: 0; }\n.statusbar .seg .k { color: var(--fg-dim); }\n.statusbar .seg .v { color: var(--fg-bright); text-shadow: var(--glow-soft); }\n.statusbar .seg.brand .v {\n  color: var(--amber);\n  text-shadow: 0 0 6px rgba(255,184,73,0.4);\n  font-weight: 700;\n  letter-spacing: 0.16em;\n}\n.statusbar .seg.warn .v  { color: var(--amber-bright); }\n.statusbar .seg.alert .v { color: var(--red-bright); animation: blink 1.4s steps(2,end) infinite; }\n.statusbar .seg.flex     { flex: 1; justify-content: flex-end; border-right: 0; }\n.statusbar .clock        { color: var(--fg-bright); }\n\n.terminal[data-mode=\"phone\"] .statusbar .seg.hide-sm { display: none; }\n", ".breadcrumb {\n  display: flex;\n  align-items: center;\n  gap: 0;\n  background: var(--bg-panel);\n  border-bottom: 1px solid var(--rule);\n  padding: 5px 10px;\n  font-size: 0.92em;\n  color: var(--fg-dim);\n  white-space: nowrap;\n  overflow: hidden;\n}\n.breadcrumb .arrow { color: var(--rule-bright); margin: 0 8px; }\n.breadcrumb .crumb { color: var(--fg); }\n.breadcrumb .crumb.active { color: var(--fg-bright); text-shadow: var(--glow-soft); }\n.breadcrumb .pill {\n  margin-left: auto;\n  background: var(--rule-dim);\n  border: 1px solid var(--rule-bright);\n  color: var(--amber);\n  padding: 1px 8px;\n  font-size: 0.95em;\n  letter-spacing: 0.1em;\n}\n", ".hotkeybar {\n  display: flex;\n  align-items: center;\n  gap: 0;\n  background: var(--bg-strip);\n  border-top: 1px solid var(--rule-bright);\n  padding: 6px 10px;\n  font-size: 0.92em;\n  white-space: nowrap;\n  overflow-x: auto;\n  scrollbar-width: none;\n}\n.hotkeybar::-webkit-scrollbar { display: none; }\n\n.hotkeybar .key {\n  padding: 0 8px 0 4px;\n  color: var(--fg);\n  border-right: 1px dashed var(--rule);\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n}\n.hotkeybar .key:last-child { border-right: 0; }\n.hotkeybar .key .k {\n  color: var(--bg-deep);\n  background: var(--fg);\n  padding: 0 5px;\n  font-weight: 700;\n  border-radius: 1px;\n}\n.hotkeybar .key .l         { color: var(--fg-dim); }\n.hotkeybar .key.special .k { background: var(--amber); }\n.hotkeybar .key.danger .k  { background: var(--red); color: var(--bg-deep); }\n", "/* Command palette \u2014 modal overlay, opened with ':'. */\n\n.palette-wrap {\n  position: absolute;\n  inset: 0;\n  background: rgba(5,8,7,0.78);\n  display: none;\n  align-items: flex-start;\n  justify-content: center;\n  padding-top: 8%;\n  z-index: 50;\n  backdrop-filter: blur(2px);\n}\n.palette-wrap.show { display: flex; }\n\n.palette {\n  width: min(88%, 60ch);\n  background: var(--bg-deep);\n  border: 1px solid var(--fg);\n  box-shadow: 0 0 0 1px var(--bg-deep) inset, 0 0 24px rgba(95,255,155,0.35);\n  padding: 0;\n}\n.palette-input {\n  display: flex;\n  align-items: baseline;\n  gap: 8px;\n  padding: 10px 12px;\n  border-bottom: 1px solid var(--rule);\n  font-size: 1.05em;\n}\n.palette-input .sigil { color: var(--amber); font-weight: 700; }\n.palette-input .field { color: var(--fg-bright); flex: 1; }\n.palette-hint { color: var(--fg-dim); font-size: 0.88em; }\n\n.palette-list { padding: 6px 0; max-height: 50vh; overflow: auto; }\n.palette-row {\n  padding: 5px 14px;\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 12px;\n  font-size: 0.96em;\n  align-items: baseline;\n  cursor: pointer;\n}\n.palette-row .name      { color: var(--fg); }\n.palette-row .name b    { color: var(--amber); font-weight: 700; }\n.palette-row .hint      { color: var(--fg-dim); font-size: 0.88em; letter-spacing: 0.08em; }\n.palette-row.sel        { background: var(--rule-dim); }\n.palette-row.sel .name  { color: var(--fg-glow); }\n", "/* HOME screen \u2014 logo, flavour, side stack, primary + secondary menus,\n * prompt line. Lifted from docs/00-VISUAL-REFERENCE.html.\n *\n * P2 spatial: HOME content sits inside .content (between breadcrumb and\n * hotkey bar). The .home class adds the layout \u2014 the layout is HOME's\n * concern, not the chrome's. */\n\n.home {\n  display: flex;\n  flex-direction: column;\n  align-items: stretch;\n  padding: 18px clamp(10px, 3vw, 28px) 14px;\n  gap: 16px;\n  min-height: 460px;\n}\n\n.home-top {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 16px;\n  align-items: start;\n}\n.terminal[data-mode=\"tablet\"]  .home-top,\n.terminal[data-mode=\"desktop\"] .home-top {\n  grid-template-columns: minmax(0, 2fr) minmax(0, 1.1fr);\n  align-items: stretch;\n}\n\n/* Side panel hide on phone */\n.terminal[data-mode=\"phone\"] .hide-on-phone { display: none; }\n\n/* Logo + tagline ---------------------------------------------------- */\n.home .logo {\n  font-family: 'VT323', 'JetBrains Mono', monospace;\n  font-size: clamp(13px, 2.1vw, 18px);\n  line-height: 1.05;\n  color: var(--fg-bright);\n  text-shadow: var(--glow-strong);\n  white-space: pre;\n  text-align: center;\n  letter-spacing: 0.04em;\n  padding: 6px 0 4px;\n}\n.home .logo .accent { color: var(--amber); text-shadow: 0 0 8px rgba(255,184,73,0.5); }\n\n.home .tagline {\n  text-align: center;\n  color: var(--fg-dim);\n  font-size: 0.9em;\n  letter-spacing: 0.34em;\n  text-transform: uppercase;\n  margin-top: -2px;\n  padding-bottom: 8px;\n  border-bottom: 1px solid var(--rule);\n}\n\n/* Flavour rows ------------------------------------------------------ */\n.home .flavor {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 4px 18px;\n  margin-top: 12px;\n  font-size: 0.95em;\n}\n.terminal[data-mode=\"tablet\"] .home .flavor,\n.terminal[data-mode=\"desktop\"] .home .flavor { grid-template-columns: repeat(3, 1fr); }\n.home .flavor .row { display: flex; gap: 8px; }\n.home .flavor .k   { color: var(--fg-dim); min-width: 9ch; }\n.home .flavor .v   { color: var(--fg-bright); }\n.home .flavor .v.warn { color: var(--amber-bright); }\n.home .flavor .v.cool { color: var(--cyan-bright); }\n\n/* Side panels ------------------------------------------------------- */\n.home .side-stack { display: flex; flex-direction: column; gap: 10px; }\n.home .panel {\n  border: 1px solid var(--rule);\n  background: var(--bg-panel);\n  padding: 10px 12px 12px;\n  position: relative;\n}\n.home .panel-title {\n  color: var(--amber);\n  font-size: 0.88em;\n  letter-spacing: 0.22em;\n  margin-bottom: 8px;\n  display: flex;\n  align-items: baseline;\n  gap: 8px;\n}\n.home .panel-title::after {\n  content: '';\n  flex: 1;\n  border-bottom: 1px dashed var(--rule);\n  transform: translateY(-3px);\n}\n.home .panel-title .badge {\n  color: var(--bg-deep);\n  background: var(--amber);\n  padding: 1px 6px;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  font-size: 0.82em;\n}\n\n.home .oneliner { font-size: 0.95em; color: var(--fg); line-height: 1.55; font-style: italic; }\n.home .oneliner .who { color: var(--fg-dim); font-style: normal; display: block; margin-top: 4px; letter-spacing: 0.1em; }\n\n.home .unread-list { display: flex; flex-direction: column; gap: 4px; font-size: 0.95em; }\n.home .unread-list .msg  { display: flex; gap: 8px; align-items: baseline; }\n.home .unread-list .from { color: var(--cyan); min-width: 10ch; }\n.home .unread-list .subj { color: var(--fg-bright); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.home .unread-list .when { color: var(--fg-dim); font-size: 0.9em; }\n\n.home .tiny-spark { color: var(--fg); letter-spacing: -0.05em; font-size: 1.05em; }\n.home .tiny-spark .lo { color: var(--fg-dim); }\n.home .tiny-spark .hi { color: var(--amber); }\n.home .spark-sub { font-size: 0.88em; color: var(--fg-dim); margin-top: 4px; }\n\n/* Menus ------------------------------------------------------------- */\n.home .menu-section-title {\n  color: var(--amber);\n  letter-spacing: 0.28em;\n  font-size: 0.88em;\n  margin: 8px 2px 8px;\n  display: flex;\n  align-items: baseline;\n  gap: 10px;\n}\n.home .menu-section-title::before,\n.home .menu-section-title::after {\n  content: '';\n  flex: 1;\n  border-bottom: 1px dashed var(--rule);\n  transform: translateY(-3px);\n}\n\n.home .menu {\n  display: grid;\n  gap: 4px 14px;\n  grid-template-columns: 1fr;\n}\n.terminal[data-mode=\"phone\"]   .home .menu { grid-template-columns: 1fr; }\n.terminal[data-mode=\"tablet\"]  .home .menu { grid-template-columns: 1fr 1fr; }\n.terminal[data-mode=\"desktop\"] .home .menu { grid-template-columns: 1fr 1fr 1fr; }\n\n.home .menu-item {\n  display: grid;\n  grid-template-columns: auto 1fr auto auto;\n  gap: 8px;\n  align-items: center;\n  padding: 5px 8px;\n  font-size: 1em;\n  cursor: pointer;\n  border: 1px solid transparent;\n  position: relative;\n}\n.home .menu-item:hover { background: var(--bg-panel-hi); border-color: var(--rule); }\n.home .menu-item.active {\n  background: var(--rule-dim);\n  border-color: var(--fg);\n  color: var(--fg-glow);\n}\n.home .menu-item .key {\n  background: var(--fg);\n  color: var(--bg-deep);\n  font-weight: 700;\n  width: 1.6em;\n  text-align: center;\n  letter-spacing: 0;\n}\n.home .menu-item .label { color: var(--fg-bright); letter-spacing: 0.16em; }\n.home .menu-item .desc  { color: var(--fg-dim); font-size: 0.9em; letter-spacing: 0.04em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.home .menu-item .pip   { color: var(--amber); font-size: 0.9em; letter-spacing: 0.08em; }\n.home .menu-item .pip.alert { color: var(--red-bright); }\n.home .menu-item .pip.cool  { color: var(--cyan-bright); }\n\n/* Prompt line ------------------------------------------------------- */\n.home .prompt {\n  margin-top: 12px;\n  padding: 10px 8px 4px;\n  border-top: 1px dashed var(--rule);\n  display: flex;\n  gap: 8px;\n  align-items: baseline;\n  color: var(--fg);\n  font-size: 1em;\n}\n.home .prompt .sigil { color: var(--amber); font-weight: 700; }\n.home .prompt .input { color: var(--fg-bright); border-bottom: 1px solid var(--rule); flex: 1; min-height: 1.4em; }\n.home .prompt-hint { color: var(--fg-dim); font-size: 0.9em; }\n.home .prompt-amber { color: var(--amber); }\n\n/* Sprint-1 placeholder card for non-HOME modules ---------------------- */\n.module-placeholder {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  min-height: 460px;\n  text-align: center;\n  padding: 32px;\n}\n.module-placeholder .ph-name {\n  font-family: 'VT323', 'JetBrains Mono', monospace;\n  font-size: clamp(20px, 3vw, 30px);\n  color: var(--amber);\n  letter-spacing: 0.18em;\n  text-shadow: 0 0 10px rgba(255,184,73,0.45);\n}\n.module-placeholder .ph-desc { color: var(--fg-dim); letter-spacing: 0.18em; }\n.module-placeholder .ph-line { color: var(--fg-bright); margin-top: 12px; }\n.module-placeholder .ph-back { color: var(--fg-dim); margin-top: 18px; font-size: 0.92em; }\n"],
