:root{--bg-deep: #050807;--bg-panel: #0a1410;--bg-panel-hi: #0f1d17;--bg-strip: #06120c;--rule-dim: #133021;--rule: #1f5538;--rule-bright: #2d7a4e;--fg-dim: #1d8c4a;--fg: #2cc26a;--fg-bright: #5fff9b;--fg-glow: #b8ffd2;--amber: #ffb849;--amber-bright: #ffd27a;--red: #ff4747;--red-bright: #ff8585;--cyan: #4adfff;--cyan-bright: #8ff0ff;--magenta: #ff5fb8;--violet: #b58cff;--paper: #d8e8d8;--char-w: clamp(7px, 1.45vw, 11px);--line-h: 1.55;--glow-soft: 0 0 6px rgba(95,255,155,.25), 0 0 14px rgba(95,255,155,.08);--glow-strong: 0 0 4px rgba(184,255,210,.55), 0 0 12px rgba(95,255,155,.35);--bp-tablet: 720px;--bp-desktop: 1100px}*{box-sizing:border-box;margin:0;padding:0}html,body{background:var(--bg-deep);color:var(--fg);font-family:JetBrains Mono,ui-monospace,Cascadia Mono,monospace;font-size:var(--char-w);line-height:var(--line-h);letter-spacing:.02em;min-height:100vh;overflow-x:hidden}body{background:radial-gradient(ellipse at 50% 20%,rgba(45,122,78,.1),transparent 60%),radial-gradient(ellipse at 50% 90%,rgba(20,80,50,.08),transparent 70%),var(--bg-deep);display:flex;flex-direction:column;align-items:center;padding:0}body:before{content:"";position:fixed;inset:0;pointer-events:none;background:repeating-linear-gradient(to bottom,#0000 0px 2px,#0000002e 3px,#0000 4px);z-index:999;opacity:.55;mix-blend-mode:multiply}body:after{content:"";position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse at center,transparent 60%,rgba(0,0,0,.45) 100%);z-index:998}:root[data-crt=off] body:before,:root[data-crt=off] body:after{display:none}@media (prefers-reduced-motion: reduce){*,*:before,*:after{animation-duration:.01ms!important}}.terminal{background:var(--bg-deep);border:1px solid var(--rule-bright);box-shadow:0 0 0 1px var(--bg-deep) inset,0 0 24px #2d7a4e2e,0 0 60px #1450321a;width:100%;position:relative;overflow:hidden}.terminal[data-mode=phone]{max-width:720px}.terminal[data-mode=tablet]{max-width:1100px}.terminal[data-mode=desktop]{max-width:1380px}.term-glow{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse at 50% 50%,transparent 55%,rgba(0,0,0,.6) 100%);z-index:1}.cursor{display:inline-block;width:.6em;height:1em;background:var(--fg-bright);margin-left:1px;vertical-align:text-bottom;animation:cursorblink 1.05s steps(2,end) infinite}@keyframes cursorblink{50%{background:transparent}}@keyframes blink{50%{opacity:.35}}.statusbar{display:flex;align-items:center;gap:0;background:var(--bg-strip);border-bottom:1px solid var(--rule-bright);padding:6px 10px;font-size:.95em;white-space:nowrap;overflow:hidden}.statusbar .seg{padding:0 10px;border-right:1px dashed var(--rule);color:var(--fg);display:flex;gap:6px;align-items:center}.statusbar .seg:first-child{padding-left:0}.statusbar .seg:last-child{border-right:0;padding-right:0}.statusbar .seg .k{color:var(--fg-dim)}.statusbar .seg .v{color:var(--fg-bright);text-shadow:var(--glow-soft)}.statusbar .seg.brand .v{color:var(--amber);text-shadow:0 0 6px rgba(255,184,73,.4);font-weight:700;letter-spacing:.16em}.statusbar .seg.warn .v{color:var(--amber-bright)}.statusbar .seg.alert .v{color:var(--red-bright);animation:blink 1.4s steps(2,end) infinite}.statusbar .seg.flex{flex:1;justify-content:flex-end;border-right:0}.statusbar .clock{color:var(--fg-bright)}.terminal[data-mode=phone] .statusbar .seg.hide-sm{display:none}.breadcrumb{display:flex;align-items:center;gap:0;background:var(--bg-panel);border-bottom:1px solid var(--rule);padding:5px 10px;font-size:.92em;color:var(--fg-dim);white-space:nowrap;overflow:hidden}.breadcrumb .arrow{color:var(--rule-bright);margin:0 8px}.breadcrumb .crumb{color:var(--fg)}.breadcrumb .crumb.active{color:var(--fg-bright);text-shadow:var(--glow-soft)}.breadcrumb .pill{margin-left:auto;background:var(--rule-dim);border:1px solid var(--rule-bright);color:var(--amber);padding:1px 8px;font-size:.95em;letter-spacing:.1em}.hotkeybar{display:flex;align-items:center;gap:0;background:var(--bg-strip);border-top:1px solid var(--rule-bright);padding:6px 10px;font-size:.92em;white-space:nowrap;overflow-x:auto;scrollbar-width:none}.hotkeybar::-webkit-scrollbar{display:none}.hotkeybar .key{padding:0 8px 0 4px;color:var(--fg);border-right:1px dashed var(--rule);display:inline-flex;align-items:center;gap:4px}.hotkeybar .key:last-child{border-right:0}.hotkeybar .key .k{color:var(--bg-deep);background:var(--fg);padding:0 5px;font-weight:700;border-radius:1px}.hotkeybar .key .l{color:var(--fg-dim)}.hotkeybar .key.special .k{background:var(--amber)}.hotkeybar .key.danger .k{background:var(--red);color:var(--bg-deep)}.palette-wrap{position:absolute;inset:0;background:#050807c7;display:none;align-items:flex-start;justify-content:center;padding-top:8%;z-index:50;backdrop-filter:blur(2px)}.palette-wrap.show{display:flex}.palette{width:min(88%,60ch);background:var(--bg-deep);border:1px solid var(--fg);box-shadow:0 0 0 1px var(--bg-deep) inset,0 0 24px #5fff9b59;padding:0}.palette-input{display:flex;align-items:baseline;gap:8px;padding:10px 12px;border-bottom:1px solid var(--rule);font-size:1.05em}.palette-input .sigil{color:var(--amber);font-weight:700}.palette-input .field{color:var(--fg-bright);flex:1}.palette-hint{color:var(--fg-dim);font-size:.88em}.palette-list{padding:6px 0;max-height:50vh;overflow:auto}.palette-row{padding:5px 14px;display:grid;grid-template-columns:1fr auto;gap:12px;font-size:.96em;align-items:baseline;cursor:pointer}.palette-row .name{color:var(--fg)}.palette-row .name b{color:var(--amber);font-weight:700}.palette-row .hint{color:var(--fg-dim);font-size:.88em;letter-spacing:.08em}.palette-row.sel{background:var(--rule-dim)}.palette-row.sel .name{color:var(--fg-glow)}.home{display:flex;flex-direction:column;align-items:stretch;padding:18px clamp(10px,3vw,28px) 14px;gap:16px;min-height:460px}.home-top{display:grid;grid-template-columns:1fr;gap:16px;align-items:start}.terminal[data-mode=tablet] .home-top,.terminal[data-mode=desktop] .home-top{grid-template-columns:minmax(0,2fr) minmax(0,1.1fr);align-items:stretch}.terminal[data-mode=phone] .hide-on-phone{display:none}.home .logo{font-family:VT323,JetBrains Mono,monospace;font-size:clamp(13px,2.1vw,18px);line-height:1.05;color:var(--fg-bright);text-shadow:var(--glow-strong);white-space:pre;text-align:center;letter-spacing:.04em;padding:6px 0 4px}.home .logo .accent{color:var(--amber);text-shadow:0 0 8px rgba(255,184,73,.5)}.home .tagline{text-align:center;color:var(--fg-dim);font-size:.9em;letter-spacing:.34em;text-transform:uppercase;margin-top:-2px;padding-bottom:8px;border-bottom:1px solid var(--rule)}.home .flavor{display:grid;grid-template-columns:repeat(2,1fr);gap:4px 18px;margin-top:12px;font-size:.95em}.terminal[data-mode=tablet] .home .flavor,.terminal[data-mode=desktop] .home .flavor{grid-template-columns:repeat(3,1fr)}.home .flavor .row{display:flex;gap:8px}.home .flavor .k{color:var(--fg-dim);min-width:9ch}.home .flavor .v{color:var(--fg-bright)}.home .flavor .v.warn{color:var(--amber-bright)}.home .flavor .v.cool{color:var(--cyan-bright)}.home .side-stack{display:flex;flex-direction:column;gap:10px}.home .panel{border:1px solid var(--rule);background:var(--bg-panel);padding:10px 12px 12px;position:relative}.home .panel-title{color:var(--amber);font-size:.88em;letter-spacing:.22em;margin-bottom:8px;display:flex;align-items:baseline;gap:8px}.home .panel-title:after{content:"";flex:1;border-bottom:1px dashed var(--rule);transform:translateY(-3px)}.home .panel-title .badge{color:var(--bg-deep);background:var(--amber);padding:1px 6px;font-weight:700;letter-spacing:.1em;font-size:.82em}.home .oneliner{font-size:.95em;color:var(--fg);line-height:1.55;font-style:italic}.home .oneliner .who{color:var(--fg-dim);font-style:normal;display:block;margin-top:4px;letter-spacing:.1em}.home .unread-list{display:flex;flex-direction:column;gap:4px;font-size:.95em}.home .unread-list .msg{display:flex;gap:8px;align-items:baseline}.home .unread-list .from{color:var(--cyan);min-width:10ch}.home .unread-list .subj{color:var(--fg-bright);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.home .unread-list .when{color:var(--fg-dim);font-size:.9em}.home .tiny-spark{color:var(--fg);letter-spacing:-.05em;font-size:1.05em}.home .tiny-spark .lo{color:var(--fg-dim)}.home .tiny-spark .hi{color:var(--amber)}.home .spark-sub{font-size:.88em;color:var(--fg-dim);margin-top:4px}.home .menu-section-title{color:var(--amber);letter-spacing:.28em;font-size:.88em;margin:8px 2px;display:flex;align-items:baseline;gap:10px}.home .menu-section-title:before,.home .menu-section-title:after{content:"";flex:1;border-bottom:1px dashed var(--rule);transform:translateY(-3px)}.home .menu{display:grid;gap:4px 14px;grid-template-columns:1fr}.terminal[data-mode=phone] .home .menu{grid-template-columns:1fr}.terminal[data-mode=tablet] .home .menu{grid-template-columns:1fr 1fr}.terminal[data-mode=desktop] .home .menu{grid-template-columns:1fr 1fr 1fr}.home .menu-item{display:grid;grid-template-columns:auto 1fr auto auto;gap:8px;align-items:center;padding:5px 8px;font-size:1em;cursor:pointer;border:1px solid transparent;position:relative}.home .menu-item:hover{background:var(--bg-panel-hi);border-color:var(--rule)}.home .menu-item.active{background:var(--rule-dim);border-color:var(--fg);color:var(--fg-glow)}.home .menu-item .key{background:var(--fg);color:var(--bg-deep);font-weight:700;width:1.6em;text-align:center;letter-spacing:0}.home .menu-item .label{color:var(--fg-bright);letter-spacing:.16em}.home .menu-item .desc{color:var(--fg-dim);font-size:.9em;letter-spacing:.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.home .menu-item .pip{color:var(--amber);font-size:.9em;letter-spacing:.08em}.home .menu-item .pip.alert{color:var(--red-bright)}.home .menu-item .pip.cool{color:var(--cyan-bright)}.home .prompt{margin-top:12px;padding:10px 8px 4px;border-top:1px dashed var(--rule);display:flex;gap:8px;align-items:baseline;color:var(--fg);font-size:1em}.home .prompt .sigil{color:var(--amber);font-weight:700}.home .prompt .input{color:var(--fg-bright);border-bottom:1px solid var(--rule);flex:1;min-height:1.4em}.home .prompt-hint{color:var(--fg-dim);font-size:.9em}.home .prompt-amber{color:var(--amber)}.module-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;min-height:460px;text-align:center;padding:32px}.module-placeholder .ph-name{font-family:VT323,JetBrains Mono,monospace;font-size:clamp(20px,3vw,30px);color:var(--amber);letter-spacing:.18em;text-shadow:0 0 10px rgba(255,184,73,.45)}.module-placeholder .ph-desc{color:var(--fg-dim);letter-spacing:.18em}.module-placeholder .ph-line{color:var(--fg-bright);margin-top:12px}.module-placeholder .ph-back{color:var(--fg-dim);margin-top:18px;font-size:.92em}
