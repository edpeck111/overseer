<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>O.V.E.R.S.E.E.R.</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glow: #33ff33;
    --glow-dim: #1a8c1a;
    --glow-bright: #66ff66;
    --glow-hot: #aaffaa;
    --amber: #ffaa00;
    --amber-dim: #996600;
    --red: #ff3333;
    --red-dim: #991a1a;
    --bg: #0a0a0a;
    --border: #1a3a1a;
  }

  /* Module color themes */
  .screen[data-module="knowledge"] {
    --glow: #33ff33; --glow-dim: #1a8c1a; --glow-bright: #66ff66;
    --glow-hot: #aaffaa; --border: #1a3a1a;
  }
  .screen[data-module="comms"] {
    --glow: #ffaa00; --glow-dim: #996600; --glow-bright: #ffcc44;
    --glow-hot: #ffddaa; --border: #3a2a0a;
  }
  .screen[data-module="recreation"] {
    --glow: #00ccff; --glow-dim: #006688; --glow-bright: #44ddff;
    --glow-hot: #aaeeff; --border: #0a2a3a;
  }
  .screen[data-module="system"] {
    --glow: #cccccc; --glow-dim: #666666; --glow-bright: #eeeeee;
    --glow-hot: #ffffff; --border: #2a2a2a;
  }

  body {
    font-family: 'Courier New', 'Lucida Console', monospace;
    background: var(--bg);
    color: var(--glow);
    min-height: 100vh;
    display: flex; flex-direction: column;
    overflow: hidden;
  }

  /* CRT scanlines */
  body::before {
    content: '';
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0,0,0,0.15) 0px,
      rgba(0,0,0,0.15) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none; z-index: 1000;
  }

  /* CRT vignette */
  body::after {
    content: '';
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.65) 100%);
    pointer-events: none; z-index: 999;
  }

  @keyframes flicker {
    0% { opacity: 0.97; } 5% { opacity: 0.95; } 10% { opacity: 0.98; }
    15% { opacity: 0.96; } 50% { opacity: 0.96; } 100% { opacity: 0.97; }
  }
  @keyframes blink {
    0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; }
  }
  @keyframes pulse-glow {
    0%, 100% { text-shadow: 0 0 4px var(--glow-dim); }
    50% { text-shadow: 0 0 8px var(--glow), 0 0 16px var(--glow-dim); }
  }
  @keyframes scan {
    0% { top: -4px; } 100% { top: 100%; }
  }
  @keyframes spin-frames {
    0% { content: '|'; } 25% { content: '/'; } 50% { content: '-'; } 75% { content: '\\'; }
  }

  /* Phosphor glow trail on new characters */
  @keyframes phosphor-burn {
    0% {
      color: #ffffff;
      text-shadow: 0 0 8px var(--glow-hot), 0 0 16px var(--glow), 0 0 24px var(--glow-dim);
    }
    30% {
      color: var(--glow-bright);
      text-shadow: 0 0 4px var(--glow), 0 0 8px var(--glow-dim);
    }
    100% {
      color: var(--glow);
      text-shadow: none;
    }
  }

  .phosphor-char {
    animation: phosphor-burn 0.6s ease-out forwards;
  }

  .screen {
    animation: flicker 4s infinite;
    display: flex; flex-direction: column;
    height: 100vh;
    max-width: 900px;
    margin: 0 auto; width: 100%;
    padding: 8px;
    position: relative;
  }

  .screen::before {
    content: '';
    position: absolute; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(transparent, rgba(51,255,51,0.08), transparent);
    animation: scan 6s linear infinite;
    pointer-events: none; z-index: 998;
  }

  .header {
    border-bottom: 1px solid var(--border);
    padding: 8px 4px 10px;
    text-align: center;
    flex-shrink: 0;
  }
  .title {
    font-size: 1.4em; font-weight: bold;
    letter-spacing: 6px; text-transform: uppercase;
    color: var(--glow-bright);
    text-shadow: 0 0 10px var(--glow), 0 0 20px var(--glow-dim), 0 0 40px rgba(51,255,51,0.2);
    animation: pulse-glow 3s ease-in-out infinite;
  }
  .subtitle {
    font-size: 0.7em; color: var(--glow-dim);
    letter-spacing: 3px; margin-top: 4px;
  }
  .operator-line {
    font-size: 0.65em; color: var(--glow-dim);
    letter-spacing: 2px; margin-top: 6px;
  }
  .operator-line .op-name {
    color: var(--glow-bright); letter-spacing: 3px;
    cursor: pointer; transition: color 0.15s;
  }
  .operator-line .op-name:hover { color: var(--glow-hot); }
  .operator-line .op-switch {
    color: var(--glow-dim); font-size: 0.85em;
    cursor: pointer; margin-left: 4px;
  }
  .operator-line .op-switch:hover { color: var(--glow); }
  /* Operator picker overlay */
  .op-picker {
    display: none; position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%); z-index: 100;
    background: #111; border: 1px solid var(--border);
    min-width: 200px; max-width: 300px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.8);
  }
  .op-picker.active { display: block; }
  .op-picker-item {
    font-family: 'Courier New', monospace;
    font-size: 0.85em; padding: 10px 14px;
    color: var(--glow); cursor: pointer;
    letter-spacing: 2px; border-bottom: 1px solid rgba(255,255,255,0.03);
    transition: background 0.15s;
  }
  .op-picker-item:hover { background: rgba(255,255,255,0.05); }
  .op-picker-item.current { color: var(--glow-bright); border-left: 2px solid var(--glow); }

  /* === MODULE NAV === */
  .module-nav {
    display: flex; gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
    background: rgba(0,0,0,0.3);
  }
  .module-nav button {
    font-family: 'Courier New', monospace;
    font-size: 0.65em; padding: 8px 12px;
    background: transparent;
    color: var(--glow-dim);
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: all 0.2s;
    flex: 1;
    position: relative;
  }
  .module-nav button:hover {
    color: var(--glow);
    background: rgba(255,255,255,0.02);
  }
  .module-nav button.active {
    color: var(--glow-bright);
    border-bottom-color: var(--glow);
    text-shadow: 0 0 6px var(--glow-dim);
  }
  .module-nav button .nav-indicator {
    display: inline-block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    margin-right: 6px;
    vertical-align: middle;
  }
  .module-nav button.active .nav-indicator {
    background: var(--glow);
    box-shadow: 0 0 6px var(--glow);
  }

  .status-bar {
    display: flex; justify-content: space-between;
    font-size: 0.65em; color: var(--glow-dim);
    padding: 4px; border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .status-bar .online { color: var(--glow); }

  /* === MODULE PANELS === */
  .module-panel {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .module-panel.active {
    display: flex;
  }

  #chat {
    flex: 1; overflow-y: auto;
    padding: 8px 4px;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }
  #chat::-webkit-scrollbar { width: 6px; }
  #chat::-webkit-scrollbar-track { background: var(--bg); }
  #chat::-webkit-scrollbar-thumb { background: var(--glow-dim); }

  .msg {
    margin: 6px 0; padding: 6px 8px;
    line-height: 1.6; font-size: 0.85em;
  }
  .msg.user {
    color: var(--amber);
    border-left: 2px solid var(--amber-dim);
    padding-left: 10px;
  }
  .msg.user::before { content: 'OPERATOR> '; color: var(--amber-dim); font-size: 0.85em; }
  .msg.assistant {
    color: var(--glow);
    padding-left: 10px;
    border-left: 2px solid var(--border);
  }
  .msg.assistant .output-area {
    white-space: pre-wrap; word-wrap: break-word;
    font-family: 'Courier New', monospace;
    font-size: 1em; line-height: 1.6;
    display: inline;
  }
  .msg.assistant .prefix {
    color: var(--glow-dim); font-size: 0.85em;
    display: block; margin-bottom: 2px;
  }
  .msg.error {
    color: var(--red);
    border-left: 2px solid var(--red-dim);
    padding-left: 10px;
  }
  .msg.error::before { content: '[! WARNING] '; color: var(--red); font-weight: bold; }

  .cursor-blink::after {
    content: '\2588';
    animation: blink 0.8s step-end infinite;
    color: var(--glow);
  }

  .loading-bar {
    padding: 6px 10px;
    border-left: 2px solid var(--border);
    margin: 6px 0;
    font-size: 0.8em;
    color: var(--glow-dim);
  }
  .loading-bar .spinner {
    display: inline-block; width: 1ch;
  }
  .loading-bar .spinner::before {
    content: '|';
    animation: spin-frames 0.5s steps(1) infinite;
  }

  .input-area {
    border-top: 1px solid var(--border);
    padding: 8px 4px;
    flex-shrink: 0;
  }
  .input-row {
    display: flex; align-items: center; gap: 4px;
  }
  .prompt-symbol {
    color: var(--glow-bright); font-size: 1em; font-weight: bold;
    flex-shrink: 0;
    text-shadow: 0 0 6px var(--glow-dim);
  }
  #input {
    flex: 1; padding: 8px;
    background: transparent; border: none;
    color: var(--glow-bright);
    font-family: 'Courier New', monospace;
    font-size: 0.9em; outline: none;
    caret-color: var(--glow);
  }
  #input::placeholder { color: var(--glow-dim); opacity: 0.5; }
  #send {
    font-family: 'Courier New', monospace;
    padding: 8px 14px;
    background: transparent; color: var(--glow);
    border: 1px solid var(--glow-dim);
    cursor: pointer; font-size: 0.8em;
    text-transform: uppercase; letter-spacing: 2px;
    transition: all 0.15s;
  }
  #send:hover {
    background: var(--glow-dim); color: #000;
    box-shadow: 0 0 12px var(--glow-dim);
  }
  #send:disabled {
    opacity: 0.3; cursor: default;
    background: transparent; color: var(--glow-dim);
  }
  .toggle-row {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.7em; color: var(--glow-dim); margin-top: 6px;
  }
  .toggle-row input[type="checkbox"] { accent-color: var(--glow); }

  /* Splash screen */
  #splash {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 2000;
    text-align: center;
  }
  #splash .splash-content {
    animation: flicker 4s infinite;
    cursor: pointer;
  }
  #splash-boot {
    animation: flicker 4s infinite;
    overflow-y: auto;
    max-height: 100vh;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }

  /* Action buttons */
  .sound-toggle {
    cursor: pointer;
    color: var(--glow-dim);
    font-size: 1em;
    user-select: none;
    padding: 0 4px;
    transition: color 0.15s;
  }
  .sound-toggle:hover { color: var(--glow); }

  /* === KNOWLEDGE SUB-TABS === */
  .knowledge-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .knowledge-tabs button {
    font-family: 'Courier New', monospace;
    font-size: 0.7em; padding: 6px 16px;
    background: transparent;
    color: var(--glow-dim);
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: all 0.2s;
  }
  .knowledge-tabs button:hover { color: var(--glow); }
  .knowledge-tabs button.active {
    color: var(--glow-bright);
    border-bottom-color: var(--glow);
  }

  /* === LIBRARY === */
  .library-panel {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .library-panel.active { display: flex; }
  .chat-panel { display: none; flex: 1; flex-direction: column; overflow: hidden; }
  .chat-panel.active { display: flex; }

  .library-search-bar {
    display: flex; gap: 4px;
    padding: 8px 4px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .library-search-bar input {
    flex: 1; padding: 8px;
    background: transparent; border: 1px solid var(--border);
    color: var(--glow-bright);
    font-family: 'Courier New', monospace;
    font-size: 0.85em; outline: none;
    caret-color: var(--glow);
  }
  .library-search-bar input::placeholder { color: var(--glow-dim); opacity: 0.5; }
  .library-search-bar input:focus { border-color: var(--glow-dim); }
  .library-search-bar button {
    font-family: 'Courier New', monospace;
    padding: 8px 14px;
    background: transparent; color: var(--glow);
    border: 1px solid var(--glow-dim);
    cursor: pointer; font-size: 0.75em;
    text-transform: uppercase; letter-spacing: 2px;
    transition: all 0.15s;
  }
  .library-search-bar button:hover {
    background: var(--glow-dim); color: #000;
  }

  .library-results {
    flex: 1;
    overflow-y: auto;
    padding: 4px;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }
  .library-results::-webkit-scrollbar { width: 6px; }
  .library-results::-webkit-scrollbar-track { background: var(--bg); }
  .library-results::-webkit-scrollbar-thumb { background: var(--glow-dim); }

  .library-result-item {
    padding: 8px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    cursor: pointer;
    transition: background 0.15s;
  }
  .library-result-item:hover {
    background: rgba(255,255,255,0.03);
  }
  .library-result-title {
    color: var(--glow-bright);
    font-size: 0.85em;
    margin-bottom: 2px;
  }
  .library-result-source {
    color: var(--glow-dim);
    font-size: 0.65em;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .library-result-count {
    color: var(--glow-dim);
    font-size: 0.7em;
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
  }

  /* Article reader */
  .article-reader {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .article-reader.active { display: flex; }
  .article-header {
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .article-back {
    font-family: 'Courier New', monospace;
    padding: 4px 10px;
    background: transparent; color: var(--glow);
    border: 1px solid var(--glow-dim);
    cursor: pointer; font-size: 0.7em;
    text-transform: uppercase;
    transition: all 0.15s;
  }
  .article-back:hover {
    background: var(--glow-dim); color: #000;
  }
  .article-title-bar {
    color: var(--glow-bright);
    font-size: 0.85em;
    letter-spacing: 1px;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .article-body-wrap {
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  .article-body-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 140px;
    background: linear-gradient(to bottom, var(--bg) 0%, var(--bg) 20%, transparent 100%);
    pointer-events: none;
    z-index: 10;
  }
  .article-body-wrap::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 140px;
    background: linear-gradient(to top, var(--bg) 0%, var(--bg) 20%, transparent 100%);
    pointer-events: none;
    z-index: 10;
  }
  .article-body {
    height: 100%;
    overflow-y: auto;
    padding: 40px 10px;
    font-size: 0.8em;
    line-height: 1.7;
    color: var(--glow);
    white-space: pre-wrap;
    word-wrap: break-word;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }
  .article-body::-webkit-scrollbar { width: 6px; }
  .article-body::-webkit-scrollbar-track { background: var(--bg); }
  .article-body::-webkit-scrollbar-thumb { background: var(--glow-dim); }

  /* Article headings */
  .article-body .ah {
    display: block;
    color: var(--glow-bright);
    margin: 1.2em 0 0.4em;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--border);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .article-body .ah-1 {
    font-size: 1.2em;
    border-bottom-color: var(--glow-dim);
    text-shadow: 0 0 8px var(--glow-dim);
    padding-bottom: 6px;
    margin-top: 0.6em;
  }
  .article-body .ah-2 {
    font-size: 1.05em;
    border-bottom-color: var(--border);
  }
  .article-body .ah-3 {
    font-size: 0.95em;
    border-bottom: none;
    color: var(--glow);
  }
  .article-body .ah-4 {
    font-size: 0.9em;
    border-bottom: none;
    color: var(--glow);
    text-transform: none;
  }

  /* Article links panel — pills/tags */
  .article-links-panel {
    flex-shrink: 0;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    height: 120px;
    min-height: 40px;
    max-height: 50vh;
  }
  .article-links-handle {
    padding: 4px 10px;
    cursor: ns-resize;
    user-select: none;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
  }
  .handle-grip {
    color: rgba(255,255,255,0.2);
    font-size: 0.6em;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .article-links-body {
    flex: 1;
    overflow-y: auto;
    padding: 6px 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-content: flex-start;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }
  .article-links-body::-webkit-scrollbar { width: 4px; }
  .article-links-body::-webkit-scrollbar-track { background: var(--bg); }
  .article-links-body::-webkit-scrollbar-thumb { background: var(--glow-dim); }
  .link-pill {
    display: inline-block;
    padding: 3px 8px;
    font-size: 0.7em;
    color: var(--glow-dim);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .link-pill:hover {
    color: var(--glow);
    border-color: var(--glow-dim);
    background: rgba(255,255,255,0.03);
  }

  .library-loading {
    padding: 12px 10px;
    color: var(--glow-dim);
    font-size: 0.8em;
  }
  .library-loading .spinner {
    display: inline-block; width: 1ch;
  }
  .library-loading .spinner::before {
    content: '|';
    animation: spin-frames 0.5s steps(1) infinite;
  }

  .library-empty {
    padding: 40px 20px;
    text-align: center;
    color: var(--glow-dim);
    font-size: 0.8em;
    line-height: 1.8;
  }

  /* === PLACEHOLDER MODULE STYLES === */
  .module-placeholder {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
  }
  .module-placeholder .ascii-art {
    font-size: 0.7em;
    line-height: 1.2;
    color: var(--glow-dim);
    margin-bottom: 24px;
    white-space: pre;
  }
  .module-placeholder .module-title {
    font-size: 1.2em;
    color: var(--glow-bright);
    letter-spacing: 4px;
    margin-bottom: 12px;
    text-shadow: 0 0 8px var(--glow-dim);
  }
  .module-placeholder .module-status {
    font-size: 0.8em;
    color: var(--glow-dim);
    margin-bottom: 8px;
  }
  .module-placeholder .module-desc {
    font-size: 0.75em;
    color: var(--glow-dim);
    max-width: 500px;
    line-height: 1.6;
    margin-top: 16px;
  }
  .module-placeholder .blink-status {
    animation: blink 1.5s step-end infinite;
    color: var(--glow);
  }

  /* === RECREATION MODULE === */
  .rec-login {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; flex: 1; padding: 20px;
  }
  .rec-login-label {
    font-size: 0.7em; color: var(--glow-dim); letter-spacing: 3px; margin-bottom: 16px;
  }
  .rec-interface { display:none; flex:1; flex-direction:column; overflow:hidden; }
  .rec-interface.active { display:flex; }
  .rec-topbar {
    display:flex; align-items:center; gap:8px; padding:6px 8px;
    border-bottom:1px solid var(--border); flex-shrink:0; font-size:0.75em;
  }
  .rec-topbar .rec-identity { color:var(--glow-bright); letter-spacing:2px; }
  .rec-topbar .rec-logout { margin-left:auto; cursor:pointer; color:var(--glow-dim); }
  .rec-topbar .rec-logout:hover { color:var(--glow); }

  /* Category / game browser */
  .rec-browser { flex:1; overflow-y:auto; padding:12px; }
  .rec-section-title {
    font-size:0.7em; color:var(--glow); letter-spacing:3px;
    margin-bottom:12px; padding-bottom:6px;
    border-bottom:1px solid var(--border);
    text-shadow:0 0 6px var(--glow-dim);
  }
  .rec-cat-grid {
    display:grid; grid-template-columns:repeat(auto-fill, minmax(140px, 1fr));
    gap:8px; margin-bottom:20px;
  }
  .rec-cat-btn {
    font-family:'Courier New',monospace; font-size:0.7em;
    padding:20px 10px; background:rgba(0,204,255,0.02);
    border:1px solid var(--border); color:var(--glow);
    cursor:pointer; text-align:center; transition:all 0.2s;
    position:relative; overflow:hidden;
  }
  .rec-cat-btn::before {
    content:''; position:absolute; top:0; left:0; right:0; height:2px;
    background:linear-gradient(90deg, transparent, var(--glow-dim), transparent);
    opacity:0; transition:opacity 0.2s;
  }
  .rec-cat-btn:hover { border-color:var(--glow-dim); background:rgba(0,204,255,0.05); }
  .rec-cat-btn:hover::before { opacity:1; }
  .rec-cat-btn .cat-icon {
    font-size:1.8em; margin-bottom:8px; display:block;
    color:var(--glow-bright); text-shadow:0 0 8px var(--glow-dim);
  }
  .rec-cat-btn .cat-name { letter-spacing:2px; display:block; color:var(--glow-bright); }
  .rec-cat-btn .cat-count { font-size:0.75em; color:var(--glow-dim); display:block; margin-top:6px; }

  /* Game list */
  .rec-game-list { flex:1; overflow-y:auto; padding:8px; }
  .rec-game-item {
    display:flex; align-items:center; gap:10px;
    padding:12px 10px; border-bottom:1px solid rgba(255,255,255,0.03);
    border-left:2px solid transparent;
    cursor:pointer; transition:all 0.15s;
  }
  .rec-game-item:hover { background:rgba(0,204,255,0.03); border-left-color:var(--glow-dim); }
  .rec-game-title { color:var(--glow-bright); font-size:0.85em; letter-spacing:1px; }
  .rec-game-desc { color:var(--glow-dim); font-size:0.7em; margin-top:3px; }
  .rec-game-stat { margin-left:auto; text-align:right; flex-shrink:0; }
  .rec-game-stat .stat-label { font-size:0.55em; color:var(--glow-dim); }
  .rec-game-stat .stat-value { font-size:0.7em; color:var(--glow); }

  /* Game play area */
  .rec-play { display:none; flex:1; flex-direction:column; overflow:hidden; }
  .rec-play.active { display:flex; }
  .rec-play-header {
    display:flex; align-items:center; gap:8px; padding:6px 8px;
    border-bottom:1px solid var(--border); flex-shrink:0;
  }
  .rec-back {
    cursor:pointer; color:var(--glow-dim); font-size:1em;
    background:transparent; border:none; font-family:'Courier New',monospace;
    padding:2px 4px;
  }
  .rec-back:hover { color:var(--glow); }
  .rec-play-title { color:var(--glow-bright); letter-spacing:2px; font-size:0.8em; }
  .rec-play-stats { margin-left:auto; font-size:0.6em; color:var(--glow-dim); }
  .rec-play-area {
    flex:1; overflow-y:auto; padding:12px; display:flex;
    flex-direction:column; align-items:center;
  }

  /* Game-specific shared styles */
  .game-board {
    font-family:'Courier New',monospace; font-size:0.85em;
    line-height:1.6; white-space:pre; color:var(--glow);
    margin:12px 0; text-align:center;
  }
  .game-msg {
    font-size:0.8em; color:var(--glow-bright); text-align:center;
    margin:8px 0; letter-spacing:1px;
  }
  .game-msg.win { color:var(--glow-bright); }
  .game-msg.lose { color:var(--red); }
  .game-input {
    font-family:'Courier New',monospace; font-size:0.85em;
    padding:8px 12px; background:rgba(255,255,255,0.03);
    border:1px solid var(--border); color:var(--glow);
    outline:none; text-align:center; letter-spacing:2px;
    width:100%; max-width:300px;
  }
  .game-input:focus { border-color:var(--glow-dim); }
  .game-btn {
    font-family:'Courier New',monospace; font-size:0.7em;
    padding:6px 16px; background:transparent;
    border:1px solid var(--glow-dim); color:var(--glow);
    cursor:pointer; letter-spacing:1px; margin:4px;
    transition:all 0.15s;
  }
  .game-btn:hover { background:var(--glow-dim); color:#000; }
  .game-btn.active { background:var(--glow); color:#000; }
  .game-btn-row { display:flex; flex-wrap:wrap; justify-content:center; gap:4px; margin:8px 0; }

  /* === SYSTEM MODULE === */
  #system-info {
    flex: 1;
    overflow-y: auto;
    padding: 12px 8px;
    font-size: 0.8em;
    line-height: 1.6;
    scrollbar-width: thin;
    scrollbar-color: var(--glow-dim) var(--bg);
  }
  #system-info::-webkit-scrollbar { width: 6px; }
  #system-info::-webkit-scrollbar-track { background: var(--bg); }
  #system-info::-webkit-scrollbar-thumb { background: var(--glow-dim); }

  .sys-section {
    margin-bottom: 16px;
  }
  .sys-section-title {
    color: var(--glow-bright);
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    margin-bottom: 8px;
    letter-spacing: 2px;
  }
  .sys-row {
    display: flex;
    gap: 8px;
    padding: 2px 0;
  }
  .sys-label {
    color: var(--glow-dim);
    min-width: 160px;
    flex-shrink: 0;
  }
  .sys-value {
    color: var(--glow);
  }

  /* === ADMIN PIN PAD === */
  .pin-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 20px;
  }
  .pin-display {
    font-size: 2em;
    letter-spacing: 12px;
    color: var(--glow-bright);
    text-shadow: 0 0 10px var(--glow-dim);
    margin-bottom: 20px;
    min-height: 1.4em;
    text-align: center;
    min-width: 160px;
    border-bottom: 2px solid var(--border);
    padding: 8px 16px;
  }
  .pin-pad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    max-width: 240px;
  }
  .pin-btn {
    font-family: 'Courier New', monospace;
    font-size: 1.4em;
    padding: 14px;
    background: rgba(255,255,255,0.03);
    color: var(--glow);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  .pin-btn:hover {
    background: rgba(255,255,255,0.06);
    border-color: var(--glow-dim);
  }
  .pin-btn:active {
    background: var(--glow-dim);
    color: #000;
  }
  .pin-btn.pin-wide {
    grid-column: span 2;
  }
  .pin-status {
    margin-top: 12px;
    font-size: 0.75em;
    color: var(--red);
    min-height: 1.2em;
  }
  .pin-label {
    font-size: 0.7em;
    color: var(--glow-dim);
    letter-spacing: 3px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  /* === ADMIN PANEL === */
  .admin-panel {
    flex: 1;
    overflow-y: auto;
    padding: 12px 8px;
    font-size: 0.8em;
    line-height: 1.6;
  }
  .admin-section {
    margin-bottom: 20px;
  }
  .admin-section-title {
    color: var(--glow-bright);
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    margin-bottom: 10px;
    letter-spacing: 2px;
    font-size: 0.85em;
  }
  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 500px;
  }
  .admin-form input, .admin-form textarea {
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    padding: 6px 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    color: var(--glow);
    outline: none;
  }
  .admin-form input:focus, .admin-form textarea:focus {
    border-color: var(--glow-dim);
  }
  .admin-form textarea {
    min-height: 60px;
    resize: vertical;
  }
  .admin-btn {
    font-family: 'Courier New', monospace;
    font-size: 0.75em;
    padding: 6px 14px;
    background: transparent;
    color: var(--glow);
    border: 1px solid var(--glow-dim);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.15s;
    align-self: flex-start;
  }
  .admin-btn:hover {
    background: var(--glow-dim);
    color: #000;
  }
  .admin-btn.danger {
    color: var(--red);
    border-color: var(--red-dim);
  }
  .admin-btn.danger:hover {
    background: var(--red-dim);
    color: #fff;
  }
  .user-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .user-card .callsign {
    color: var(--glow-bright);
    min-width: 100px;
    letter-spacing: 1px;
  }
  .user-card .key-preview {
    color: var(--glow-dim);
    font-size: 0.8em;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .admin-msg {
    padding: 6px 0;
    font-size: 0.85em;
  }
  .admin-msg.ok { color: var(--glow); }
  .admin-msg.err { color: var(--red); }

  /* === COMMS MODULE === */
  .comms-login {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 20px;
  }
  .comms-login-label {
    font-size: 0.7em;
    color: var(--glow-dim);
    letter-spacing: 3px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .comms-user-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 300px;
    width: 100%;
  }
  .comms-user-btn {
    font-family: 'Courier New', monospace;
    font-size: 0.85em;
    padding: 10px 16px;
    background: rgba(255,255,255,0.03);
    color: var(--glow);
    border: 1px solid var(--border);
    cursor: pointer;
    text-align: left;
    letter-spacing: 2px;
    transition: all 0.15s;
  }
  .comms-user-btn:hover {
    border-color: var(--glow-dim);
    background: rgba(255,255,255,0.05);
  }
  .comms-interface {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .comms-interface.active { display: flex; }
  .comms-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    font-size: 0.75em;
  }
  .comms-topbar .comms-identity {
    color: var(--glow-bright);
    letter-spacing: 2px;
  }
  .comms-topbar .comms-logout {
    margin-left: auto;
    cursor: pointer;
    color: var(--glow-dim);
    transition: color 0.15s;
  }
  .comms-topbar .comms-logout:hover { color: var(--glow); }

  /* Conversation list */
  .comms-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }
  .comms-conv-header {
    display: flex;
    align-items: center;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    font-size: 0.65em;
    color: var(--glow-dim);
    letter-spacing: 2px;
  }
  .comms-conv-header .comms-new-btn {
    margin-left: auto;
    cursor: pointer;
    color: var(--glow);
    font-size: 1em;
    background: transparent;
    border: 1px solid var(--border);
    padding: 2px 8px;
    font-family: 'Courier New', monospace;
    letter-spacing: 1px;
    transition: all 0.15s;
  }
  .comms-conv-header .comms-new-btn:hover { border-color: var(--glow-dim); }
  .conv-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    cursor: pointer;
    transition: background 0.15s;
  }
  .conv-item:hover { background: rgba(255,255,255,0.03); }
  .conv-item.active { background: rgba(255,255,255,0.06); border-left: 2px solid var(--glow); }
  .conv-item.pending { border-left: 2px solid var(--amber); }
  .conv-info { flex: 1; min-width: 0; }
  .conv-callsign {
    color: var(--glow-bright);
    font-size: 0.8em;
    letter-spacing: 1px;
  }
  .conv-preview {
    color: var(--glow-dim);
    font-size: 0.7em;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .conv-meta {
    text-align: right;
    flex-shrink: 0;
  }
  .conv-time {
    color: var(--glow-dim);
    font-size: 0.6em;
  }
  .conv-badge {
    display: inline-block;
    background: var(--glow);
    color: #000;
    font-size: 0.55em;
    padding: 1px 5px;
    margin-top: 2px;
    letter-spacing: 0;
    font-weight: bold;
  }
  .conv-status-label {
    display: inline-block;
    font-size: 0.55em;
    padding: 1px 5px;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-left: 6px;
  }
  .conv-status-pending { background: var(--amber-dim); color: #000; }
  .conv-status-blocked { background: var(--red-dim); color: #fff; }

  /* Chat thread */
  .comms-thread {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .comms-thread.active { display: flex; }
  .comms-thread-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    font-size: 0.75em;
  }
  .comms-thread-back {
    cursor: pointer;
    color: var(--glow-dim);
    font-size: 1em;
    background: transparent;
    border: none;
    font-family: 'Courier New', monospace;
    padding: 2px 4px;
    transition: color 0.15s;
  }
  .comms-thread-back:hover { color: var(--glow); }
  .comms-thread-name {
    color: var(--glow-bright);
    letter-spacing: 2px;
  }
  .comms-thread-actions {
    margin-left: auto;
    display: flex;
    gap: 4px;
  }
  .comms-thread-actions button {
    font-family: 'Courier New', monospace;
    font-size: 0.6em;
    padding: 2px 6px;
    background: transparent;
    border: 1px solid;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.15s;
  }
  .thread-accept { color: var(--glow); border-color: var(--glow-dim); }
  .thread-accept:hover { background: var(--glow-dim); color: #000; }
  .thread-block { color: var(--red); border-color: var(--red-dim); }
  .thread-block:hover { background: var(--red-dim); color: #fff; }
  .comms-messages {
    flex: 1;
    overflow-y: auto;
    padding: 8px 10px 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .chat-bubble {
    max-width: 85%;
    padding: 6px 10px;
    font-size: 0.8em;
    line-height: 1.5;
    word-wrap: break-word;
    white-space: pre-wrap;
    border: 1px solid var(--border);
  }
  .chat-bubble.sent {
    align-self: flex-end;
    background: rgba(255,255,255,0.05);
    border-color: var(--glow-dim);
  }
  .chat-bubble.received {
    align-self: flex-start;
    background: rgba(255,255,255,0.02);
  }
  .chat-meta {
    font-size: 0.6em;
    color: var(--glow-dim);
    margin-top: 2px;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .chat-bubble.sent .chat-meta { justify-content: flex-end; }
  .delivery-tick {
    font-size: 0.9em;
  }
  .delivery-tick.queued { color: var(--glow-dim); }
  .delivery-tick.sent { color: var(--glow-dim); }
  .delivery-tick.delivered { color: var(--glow); }
  .delivery-tick.read { color: var(--glow-bright); }

  /* Chat input bar */
  .comms-input-bar {
    display: flex;
    gap: 6px;
    padding: 6px 8px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    align-items: flex-end;
  }
  .comms-input-bar textarea {
    flex: 1;
    font-family: 'Courier New', monospace;
    font-size: 0.8em;
    padding: 6px 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    color: var(--glow);
    outline: none;
    resize: none;
    min-height: 32px;
    max-height: 100px;
    line-height: 1.4;
  }
  .comms-input-bar textarea:focus { border-color: var(--glow-dim); }
  .comms-input-bar .char-count {
    font-size: 0.55em;
    color: var(--glow-dim);
    flex-shrink: 0;
    align-self: center;
    min-width: 40px;
    text-align: right;
  }
  .comms-input-bar .char-count.warn { color: var(--amber); }
  .comms-input-bar .char-count.over { color: var(--red); }
  .comms-send-btn {
    font-family: 'Courier New', monospace;
    font-size: 0.7em;
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--glow-dim);
    color: var(--glow);
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .comms-send-btn:hover { background: var(--glow-dim); color: #000; }

  /* New message — recipient picker */
  .comms-new-msg {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .comms-new-msg.active { display: flex; }
  .comms-new-msg-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    font-size: 0.75em;
  }
  .comms-new-msg-list {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }

  .comms-empty {
    padding: 40px 20px;
    text-align: center;
    color: var(--glow-dim);
    font-size: 0.8em;
  }

  @media (max-width: 600px) {
    .title { font-size: 1.1em; letter-spacing: 3px; }
    .msg { font-size: 0.8em; }
    .status-bar { display: none; }
    .module-nav button { font-size: 0.65em; padding: 8px 4px; letter-spacing: 1px; }
    .module-nav button .nav-indicator { width: 5px; height: 5px; margin-right: 3px; }
    .module-placeholder .ascii-art { font-size: 0.5em; }
    .knowledge-tabs button { font-size: 0.65em; padding: 5px 10px; }
    .library-search-bar input { font-size: 0.8em; }
    .article-body { font-size: 0.75em; }
    .rec-cat-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .rec-cat-btn { padding: 20px 10px; }
    .rec-cat-btn .cat-icon { font-size: 2em; }
    .rec-topbar { display: none; }
    .comms-topbar { display: none; }
  }
</style>
</head>
<body>
<!-- SPLASH / BOOT SCREEN -->
<div id="splash" onclick="startBoot()">
  <div style="width:100%; max-width:700px; padding:20px;">
    <div class="splash-content" id="splash-title" style="text-align:center; margin-bottom:24px;">
      <div class="title" style="margin-bottom:16px;">OVERSEER</div>
      <div style="color:var(--glow-dim);font-size:0.7em;letter-spacing:2px;">
        Offline Vault of Essential Records for<br>Survival, Emergency &amp; Endurance Response
      </div>
    </div>
    <div id="splash-boot" style="display:none; font-size:0.8em; line-height:1.6;">
      <span id="boot-output" class="output-area" style="white-space:pre-wrap;"></span>
    </div>
    <div id="splash-prompt" style="text-align:center; margin-top:20px;">
      <div style="color:var(--glow);font-size:0.9em;animation:blink 1.2s step-end infinite; cursor:pointer;">
        [ CLICK TO INITIALIZE ]
      </div>
    </div>
  </div>
</div>

<!-- MAIN TERMINAL -->
<div class="screen" id="terminal" data-module="knowledge" style="display:none;">
  <div class="header" style="position:relative;">
    <div class="title">OVERSEER</div>
    <div class="subtitle">Offline Vault of Essential Records for Survival, Emergency &amp; Endurance Response</div>
    <div class="operator-line" id="header-operator">OPERATOR: <span class="op-name" id="header-op-name" onclick="toggleOperatorPicker()">---</span><span class="op-switch" onclick="toggleOperatorPicker()">[SWITCH]</span></div>
    <div class="op-picker" id="op-picker"></div>
  </div>

  <!-- MODULE NAVIGATION -->
  <div class="module-nav">
    <button class="active" onclick="switchModule('knowledge')" id="nav-knowledge">
      <span class="nav-indicator"></span>KNOWLEDGE
    </button>
    <button onclick="switchModule('comms')" id="nav-comms">
      <span class="nav-indicator"></span>COMMS
    </button>
    <button onclick="switchModule('recreation')" id="nav-recreation">
      <span class="nav-indicator"></span>RECREATION
    </button>
    <button onclick="switchModule('system')" id="nav-system">
      <span class="nav-indicator"></span>SYSTEM
    </button>
  </div>

  <div class="status-bar">
    <span>SYS: <span class="online" id="sysStatus">BOOTING</span></span>
    <span id="statusModel">MODEL: ---</span>
    <span id="statusRam">RAM: ---</span>
    <span id="statusKb">KB: ---</span>
    <span id="clock"></span>
  </div>

  <!-- ==================== KNOWLEDGE MODULE ==================== -->
  <div id="module-knowledge" class="module-panel active">
    <div class="knowledge-tabs">
      <button class="active" onclick="switchKnowledgeTab('chat')" id="ktab-chat">CHAT</button>
      <button onclick="switchKnowledgeTab('library')" id="ktab-library">LIBRARY</button>
    </div>

    <!-- CHAT SUB-PANEL -->
    <div id="knowledge-chat" class="chat-panel active">
      <div id="chat"></div>
      <div class="input-area">
        <div class="input-row">
          <span class="prompt-symbol">&gt;_</span>
          <input type="text" id="input" placeholder="ENTER QUERY..." autocomplete="off" spellcheck="false">
          <button id="send" onclick="send()">TRANSMIT</button>
        </div>
        <div class="toggle-row">
          <input type="checkbox" id="rag" checked>
          <label for="rag">[KNOWLEDGE BASE AUGMENTATION]</label>
          <span class="sound-toggle" onclick="clearChat()">[CLR]</span>
          <span class="sound-toggle" onclick="exportChat()">[EXPORT]</span>
          <span class="sound-toggle" onclick="toggleSound()" id="soundToggle">[SND: ON]</span>
        </div>
      </div>
    </div>

    <!-- LIBRARY SUB-PANEL -->
    <div id="knowledge-library" class="library-panel">
      <div class="library-search-bar">
        <input type="text" id="library-search" placeholder="SEARCH ARCHIVES..." autocomplete="off" spellcheck="false">
        <button onclick="librarySearch()">SEARCH</button>
        <button onclick="showBookList()" title="Browse volumes" style="letter-spacing:0;">BROWSE</button>
      </div>
      <div id="library-content" class="library-results">
        <div class="library-empty">
          SEARCH to find articles across all archives, or<br>
          BROWSE to explore individual volumes.<br><br>
          All content is available offline from the loaded ZIM volumes.
        </div>
      </div>

      <!-- Article reader (hidden until an article is selected) -->
      <div id="article-reader" class="article-reader">
        <div class="article-header">
          <button class="article-back" onclick="closeArticle()">&lt; BACK</button>
          <span class="article-title-bar" id="article-title">---</span>
        </div>
        <div class="article-body-wrap">
          <div class="article-body" id="article-body"></div>
        </div>
        <div id="article-links" class="article-links-panel" style="display:none;">
          <div class="article-links-handle" id="article-links-handle">
            <span class="handle-grip">\u2261 LINKED ARTICLES</span>
          </div>
          <div class="article-links-body" id="article-links-list"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== COMMS MODULE ==================== -->
  <div id="module-comms" class="module-panel">
    <!-- Main comms interface (uses global operator) -->
    <div id="comms-interface" class="comms-interface active">
      <div class="comms-topbar">
        <span>OPERATOR:</span>
        <span class="comms-identity" id="comms-identity">---</span>
      </div>

      <!-- Conversation list view -->
      <div id="comms-conversations" style="display:flex; flex-direction:column; flex:1; overflow:hidden;">
        <div class="comms-conv-header">
          <span>CONVERSATIONS</span>
          <button class="comms-new-btn" onclick="commsShowNewMsg()">+ NEW</button>
        </div>
        <div id="comms-conv-list" class="comms-conv-list"></div>
      </div>

      <!-- Chat thread view -->
      <div id="comms-thread" class="comms-thread">
        <div class="comms-thread-header">
          <button class="comms-thread-back" onclick="commsBackToList()">&lt;</button>
          <span class="comms-thread-name" id="thread-contact-name">---</span>
          <div class="comms-thread-actions" id="thread-actions"></div>
        </div>
        <div id="comms-messages" class="comms-messages"></div>
        <div class="comms-input-bar">
          <textarea id="chat-input" rows="1" placeholder="Type message..." autocomplete="off" spellcheck="false"
                    oninput="chatInputResize(this); chatUpdateCharCount();"
                    onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();commsSend();}"></textarea>
          <span class="char-count" id="chat-char-count"></span>
          <button class="comms-send-btn" onclick="commsSend()">SEND</button>
        </div>
      </div>

      <!-- New message — pick recipient -->
      <div id="comms-new-msg" class="comms-new-msg">
        <div class="comms-new-msg-header">
          <button class="comms-thread-back" onclick="commsBackToList()">&lt;</button>
          <span style="color:var(--glow-dim); letter-spacing:2px;">NEW MESSAGE</span>
        </div>
        <div id="comms-new-msg-list" class="comms-new-msg-list"></div>
      </div>
    </div>
  </div>

  <!-- ==================== RECREATION MODULE ==================== -->
  <div id="module-recreation" class="module-panel">
    <!-- Main interface (uses global operator) -->
    <div id="rec-interface" class="rec-interface active">
      <div class="rec-topbar">
        <span>OPERATOR:</span>
        <span class="rec-identity" id="rec-identity">---</span>
      </div>

      <!-- Category browser -->
      <div id="rec-browser" class="rec-browser">
        <div class="rec-section-title">GAME CATEGORIES</div>
        <div class="rec-cat-grid" id="rec-categories"></div>
      </div>

      <!-- Game list within category -->
      <div id="rec-gamelist" style="display:none; flex-direction:column; flex:1; overflow:hidden;">
        <div style="display:flex; align-items:center; gap:8px; padding:6px 8px; border-bottom:1px solid var(--border);">
          <button class="rec-back" onclick="recShowCategories()">&lt;</button>
          <span id="rec-cat-title" style="color:var(--glow-dim);letter-spacing:2px;font-size:0.75em;"></span>
        </div>
        <div id="rec-game-list" class="rec-game-list"></div>
      </div>

      <!-- Game play area -->
      <div id="rec-play" class="rec-play">
        <div class="rec-play-header">
          <button class="rec-back" onclick="recExitGame()">&lt;</button>
          <span class="rec-play-title" id="rec-play-title">---</span>
          <span class="rec-play-stats" id="rec-play-stats"></span>
        </div>
        <div id="rec-play-area" class="rec-play-area"></div>
      </div>
    </div>
  </div>

  <!-- ==================== SYSTEM MODULE ==================== -->
  <div id="module-system" class="module-panel">
    <div class="knowledge-tabs">
      <button class="active" onclick="switchSystemTab('status')" id="systab-status">STATUS</button>
      <button onclick="switchSystemTab('admin')" id="systab-admin">ADMIN</button>
    </div>

    <!-- STATUS SUB-PANEL -->
    <div id="system-status" class="chat-panel active">
      <div id="system-info">
        <div class="sys-section">
          <div class="sys-section-title">--- SYSTEM STATUS ---</div>
          <div id="sys-core-info">Loading system information...</div>
        </div>
        <div class="sys-section">
          <div class="sys-section-title">--- LOADED MODELS ---</div>
          <div id="sys-models">Scanning...</div>
        </div>
        <div class="sys-section">
          <div class="sys-section-title">--- KNOWLEDGE ARCHIVES ---</div>
          <div id="sys-archives">Indexing...</div>
        </div>
      </div>
    </div>

    <!-- ADMIN SUB-PANEL -->
    <div id="system-admin" class="library-panel">
      <!-- PIN entry (shown when locked) -->
      <div id="admin-pin-screen" class="pin-overlay">
        <div class="pin-label">ADMIN AUTHENTICATION</div>
        <div class="pin-display" id="pin-display"></div>
        <div class="pin-pad">
          <div class="pin-btn" onclick="pinPress('1')">1</div>
          <div class="pin-btn" onclick="pinPress('2')">2</div>
          <div class="pin-btn" onclick="pinPress('3')">3</div>
          <div class="pin-btn" onclick="pinPress('4')">4</div>
          <div class="pin-btn" onclick="pinPress('5')">5</div>
          <div class="pin-btn" onclick="pinPress('6')">6</div>
          <div class="pin-btn" onclick="pinPress('7')">7</div>
          <div class="pin-btn" onclick="pinPress('8')">8</div>
          <div class="pin-btn" onclick="pinPress('9')">9</div>
          <div class="pin-btn" onclick="pinClear()">CLR</div>
          <div class="pin-btn" onclick="pinPress('0')">0</div>
          <div class="pin-btn" onclick="pinSubmit()">ENT</div>
        </div>
        <div class="pin-status" id="pin-status"></div>
      </div>

      <!-- Admin panel (shown when unlocked) -->
      <div id="admin-panel" class="admin-panel" style="display:none;">
        <div class="admin-section">
          <div class="admin-section-title">--- REGISTERED OPERATORS ---</div>
          <div id="admin-user-list"></div>
        </div>
        <div class="admin-section">
          <div class="admin-section-title">--- REGISTER NEW OPERATOR ---</div>
          <div class="admin-form">
            <input type="text" id="admin-callsign" placeholder="CALLSIGN (e.g. ALPHA-1)" autocomplete="off" spellcheck="false">
            <textarea id="admin-pubkey" placeholder="PASTE PUBLIC KEY (PEM format)"></textarea>
            <div style="display:flex; gap:6px;">
              <button class="admin-btn" onclick="adminRegisterUser()">REGISTER</button>
              <button class="admin-btn" onclick="adminGenerateKeypair()">GENERATE KEYPAIR</button>
            </div>
            <div class="admin-msg" id="admin-register-msg"></div>
          </div>
        </div>
        <div class="admin-section">
          <div class="admin-section-title">--- BLOCKED CONTACTS ---</div>
          <div id="admin-blocks-list"></div>
        </div>
        <div class="admin-section">
          <div class="admin-section-title">--- CHANGE ADMIN PIN ---</div>
          <div class="admin-form">
            <input type="password" id="admin-old-pin" placeholder="CURRENT PIN" autocomplete="off">
            <input type="password" id="admin-new-pin" placeholder="NEW PIN (min 4 digits)" autocomplete="off">
            <button class="admin-btn" onclick="adminChangePin()">UPDATE PIN</button>
            <div class="admin-msg" id="admin-pin-msg"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
let chat, input, sendBtn;
const conversationHistory = [];
let charQueue = [];
let isTyping = false;
let outputArea = null;
let charsSinceSound = 0;
let CHAR_DELAY = 18;
const CHAR_DELAY_NORMAL = 18;
const CHAR_DELAY_FAST = 3;
const STORAGE_KEY = 'overseer_chat_history';
let bootInfo = null;

// === MODULE SWITCHING ===
function switchModule(name) {
  const screen = document.getElementById('terminal');
  screen.setAttribute('data-module', name);

  // Update nav buttons
  document.querySelectorAll('.module-nav button').forEach(btn => btn.classList.remove('active'));
  document.getElementById('nav-' + name).classList.add('active');

  // Update panels
  document.querySelectorAll('.module-panel').forEach(panel => panel.classList.remove('active'));
  document.getElementById('module-' + name).classList.add('active');

  // Focus input if switching to knowledge
  if (name === 'knowledge' && input) {
    setTimeout(() => input.focus(), 50);
  }

  // Populate system info if switching to system and we have boot data
  if (name === 'system' && bootInfo) {
    populateSystemInfo(bootInfo);
  }

  // Load conversations if switching to comms
  if (name === 'comms' && activeUserId) {
    commsShowConversations();
  }

  // Load game sync/categories if switching to recreation
  if (name === 'recreation' && activeUserId) {
    recShowSync();
  }
}

function populateSystemInfo(info) {
  // Core info
  let coreHtml = '';
  coreHtml += '<div class="sys-row"><span class="sys-label">VERSION:</span><span class="sys-value">v' + info.version + '</span></div>';
  coreHtml += '<div class="sys-row"><span class="sys-label">BUILD DATE:</span><span class="sys-value">' + info.build_date + '</span></div>';
  coreHtml += '<div class="sys-row"><span class="sys-label">CODENAME:</span><span class="sys-value">' + info.codename + '</span></div>';
  coreHtml += '<div class="sys-row"><span class="sys-label">SYSTEM RAM:</span><span class="sys-value">' + info.ram_total_gb + ' GB total / ' + info.ram_free_gb + ' GB free</span></div>';
  coreHtml += '<div class="sys-row"><span class="sys-label">INFERENCE ENGINE:</span><span class="sys-value">' + info.inference_engine + '</span></div>';
  coreHtml += '<div class="sys-row"><span class="sys-label">KB SERVER:</span><span class="sys-value">' + info.knowledge_server + '</span></div>';
  document.getElementById('sys-core-info').innerHTML = coreHtml;

  // Models
  let modelsHtml = '';
  if (info.models.length > 0) {
    info.models.forEach(m => {
      modelsHtml += '<div class="sys-row"><span class="sys-label">' + m.name + '</span><span class="sys-value">' + m.size_gb + ' GB  |  Pulled: ' + m.date + '</span></div>';
    });
  } else {
    modelsHtml = '<div style="color:var(--red);">[!] NO MODELS DETECTED</div>';
  }
  document.getElementById('sys-models').innerHTML = modelsHtml;

  // Archives
  let archivesHtml = '';
  if (info.zim_files.length > 0) {
    info.zim_files.forEach(z => {
      archivesHtml += '<div class="sys-row"><span class="sys-label">' + z.name + '</span><span class="sys-value">[' + z.size_gb + ' GB]  (' + z.date + ')</span></div>';
      archivesHtml += '<div style="padding-left:168px;color:var(--glow-dim);font-size:0.9em;">' + z.desc + '</div>';
    });
    archivesHtml += '<div class="sys-row" style="margin-top:8px;border-top:1px solid var(--border);padding-top:8px;"><span class="sys-label">TOTAL ARCHIVE SIZE:</span><span class="sys-value">' + info.total_kb_size_gb + ' GB</span></div>';
  } else {
    archivesHtml = '<div style="color:var(--red);">[!] NO KNOWLEDGE ARCHIVES FOUND</div>';
  }
  document.getElementById('sys-archives').innerHTML = archivesHtml;
}

// === AUDIO ENGINE ===
let audioCtx = null;
let soundEnabled = true;
const keyBuffers = [];
let keysLoaded = false;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

function toggleSound() {
  soundEnabled = !soundEnabled;
  document.getElementById('soundToggle').textContent = soundEnabled ? '[SND: ON]' : '[SND: OFF]';
}

async function loadKeySounds() {
  const ctx = getAudioCtx();
  for (let i = 1; i <= 8; i++) {
    try {
      const num = String(i).padStart(2, '0');
      const resp = await fetch('/sounds/key' + num + '.wav');
      const buf = await resp.arrayBuffer();
      const decoded = await ctx.decodeAudioData(buf);
      keyBuffers.push(decoded);
    } catch(e) { console.warn('Failed to load key' + i, e); }
  }
  keysLoaded = keyBuffers.length > 0;
}

function playKeystroke() {
  if (!soundEnabled || !keysLoaded) return;
  try {
    const ctx = getAudioCtx();
    const buf = keyBuffers[Math.floor(Math.random() * keyBuffers.length)];
    const src = ctx.createBufferSource();
    src.buffer = buf;
    src.playbackRate.value = 0.95 + Math.random() * 0.1;
    const gain = ctx.createGain();
    gain.gain.value = 0.5 + Math.random() * 0.15;
    src.connect(gain);
    gain.connect(ctx.destination);
    src.start();
  } catch(e) {}
}

function playNewline() {
  if (!soundEnabled || !keysLoaded) return;
  try {
    const ctx = getAudioCtx();
    const buf = keyBuffers[Math.floor(Math.random() * keyBuffers.length)];
    const src = ctx.createBufferSource();
    src.buffer = buf;
    src.playbackRate.value = 0.7;
    const gain = ctx.createGain();
    gain.gain.value = 0.35;
    src.connect(gain);
    gain.connect(ctx.destination);
    src.start();
  } catch(e) {}
}

function playError() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const t = ctx.currentTime;
    for (let i = 0; i < 2; i++) {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 330;
      gain.gain.setValueAtTime(0.2, t + i * 0.2);
      gain.gain.exponentialRampToValueAtTime(0.001, t + i * 0.2 + 0.15);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start(t + i * 0.2);
      osc.stop(t + i * 0.2 + 0.15);
    }
  } catch(e) {}
}

// === CLOCK ===
function updateClock() {
  const el = document.getElementById('clock');
  if (!el) return;
  const now = new Date();
  const h = String(now.getHours()).padStart(2, '0');
  const m = String(now.getMinutes()).padStart(2, '0');
  const s = String(now.getSeconds()).padStart(2, '0');
  el.textContent = h + ':' + m + ':' + s;
}
setInterval(updateClock, 1000);
updateClock();

function bindInputEvents() {
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); send(); }
  });
  document.getElementById('library-search').addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); librarySearch(); }
  });
}

// === KNOWLEDGE SUB-TABS ===
function switchKnowledgeTab(tab) {
  document.querySelectorAll('.knowledge-tabs button').forEach(b => b.classList.remove('active'));
  document.getElementById('ktab-' + tab).classList.add('active');

  document.getElementById('knowledge-chat').classList.toggle('active', tab === 'chat');
  document.getElementById('knowledge-library').classList.toggle('active', tab === 'library');

  if (tab === 'chat') input.focus();
  if (tab === 'library') document.getElementById('library-search').focus();
}

// === LIBRARY ===
let libraryHistory = []; // navigation stack for back button

async function showBookList() {
  const contentDiv = document.getElementById('library-content');
  const readerDiv = document.getElementById('article-reader');
  readerDiv.classList.remove('active');
  contentDiv.style.display = '';
  libraryHistory = [];

  contentDiv.innerHTML = '<div class="library-loading"><span class="spinner"></span> LOADING CATALOG...</div>';

  try {
    const resp = await fetch('/library/books');
    const data = await resp.json();

    if (data.error) {
      contentDiv.innerHTML = '<div class="library-empty">[!] ' + esc(data.error) + '</div>';
      return;
    }

    if (data.books.length === 0) {
      contentDiv.innerHTML = '<div class="library-empty">No volumes loaded.<br>Check that ZIM files are in the /zim directory.</div>';
      return;
    }

    let html = '<div class="library-result-count">' + data.books.length + ' volumes loaded</div>';
    data.books.forEach(b => {
      html += '<div class="library-result-item" onclick="openArticle(\'' + b.path.replace(/'/g, "\\'") + '\')">';
      html += '<div class="library-result-title">' + esc(b.title) + '</div>';
      let meta = '';
      if (b.articles) meta += b.articles + ' articles';
      if (b.summary) meta += (meta ? ' \u2014 ' : '') + b.summary.substring(0, 100);
      if (meta) html += '<div class="library-result-source">' + esc(meta) + '</div>';
      html += '</div>';
    });
    contentDiv.innerHTML = html;
  } catch(e) {
    contentDiv.innerHTML = '<div class="library-empty">[!] CATALOG FAILED \u2014 Cannot reach knowledge server.</div>';
  }
}

async function librarySearch() {
  const q = document.getElementById('library-search').value.trim();
  if (!q) return;

  const contentDiv = document.getElementById('library-content');
  const readerDiv = document.getElementById('article-reader');

  readerDiv.classList.remove('active');
  contentDiv.style.display = '';
  libraryHistory = [];

  contentDiv.innerHTML = '<div class="library-loading"><span class="spinner"></span> SEARCHING ARCHIVES...</div>';

  try {
    const resp = await fetch('/library/search?q=' + encodeURIComponent(q) + '&limit=30');
    const data = await resp.json();

    if (data.error) {
      contentDiv.innerHTML = '<div class="library-empty">[!] ' + esc(data.error) + '</div>';
      return;
    }

    if (data.results.length === 0) {
      contentDiv.innerHTML = '<div class="library-empty">No results found for "' + esc(q) + '".<br>Try different search terms.</div>';
      return;
    }

    let html = '<div class="library-result-count">' + data.results.length + ' results found</div>';
    data.results.forEach(r => {
      html += '<div class="library-result-item" onclick="openArticle(\'' + r.link.replace(/'/g, "\\'") + '\')">';
      html += '<div class="library-result-title">' + esc(r.title) + '</div>';
      html += '<div class="library-result-source">' + esc(r.source) + '</div>';
      html += '</div>';
    });
    contentDiv.innerHTML = html;
  } catch(e) {
    contentDiv.innerHTML = '<div class="library-empty">[!] SEARCH FAILED \u2014 Cannot reach knowledge server.</div>';
  }
}

async function openArticle(path) {
  const contentDiv = document.getElementById('library-content');
  const readerDiv = document.getElementById('article-reader');
  const titleBar = document.getElementById('article-title');
  const bodyDiv = document.getElementById('article-body');
  const linksPanel = document.getElementById('article-links');
  const linksList = document.getElementById('article-links-list');

  titleBar.textContent = 'LOADING...';
  bodyDiv.textContent = '';
  linksPanel.style.display = 'none';
  linksList.innerHTML = '';

  contentDiv.style.display = 'none';
  readerDiv.classList.add('active');

  try {
    const resp = await fetch('/library/article?path=' + encodeURIComponent(path));
    const data = await resp.json();

    if (data.error) {
      titleBar.textContent = 'ERROR';
      bodyDiv.textContent = data.error;
      return;
    }

    titleBar.textContent = data.title;
    bodyDiv.innerHTML = formatArticleText(data.text);
    bodyDiv.scrollTop = 0;

    // Show linked articles as pills
    if (data.links && data.links.length > 0) {
      linksPanel.style.display = '';
      let linksHtml = '';
      data.links.forEach(lnk => {
        linksHtml += '<span class="link-pill" onclick="navigateArticle(\'' + lnk.link.replace(/'/g, "\\'") + '\')" title="' + esc(lnk.title) + '">';
        linksHtml += esc(lnk.title);
        linksHtml += '</span>';
      });
      linksList.innerHTML = linksHtml;
    }
  } catch(e) {
    titleBar.textContent = 'ERROR';
    bodyDiv.textContent = 'Failed to load article. Knowledge server may be offline.';
  }
}

function navigateArticle(path) {
  // Push current state to history for back button
  const titleBar = document.getElementById('article-title');
  libraryHistory.push({
    title: titleBar.textContent,
    path: path
  });
  openArticle(path);
}

// === DRAG-RESIZE LINKED ARTICLES PANEL ===
(function() {
  let dragging = false;
  let startY = 0;
  let startH = 0;

  document.addEventListener('mousedown', e => {
    const handle = document.getElementById('article-links-handle');
    if (!handle || !handle.contains(e.target)) return;
    const panel = document.getElementById('article-links');
    dragging = true;
    startY = e.clientY;
    startH = panel.offsetHeight;
    e.preventDefault();
  });

  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    const panel = document.getElementById('article-links');
    const delta = startY - e.clientY;  // drag up = bigger
    const newH = Math.max(40, Math.min(window.innerHeight * 0.5, startH + delta));
    panel.style.height = newH + 'px';
  });

  document.addEventListener('mouseup', () => { dragging = false; });
})();

function closeArticle() {
  if (libraryHistory.length > 0) {
    // Go back in article navigation history
    const prev = libraryHistory.pop();
    // We need the *previous* article's path, but we stored the destination path
    // So we just go back to the results list if history is a simple stack
  }

  const contentDiv = document.getElementById('library-content');
  const readerDiv = document.getElementById('article-reader');

  readerDiv.classList.remove('active');
  contentDiv.style.display = '';
}

// === TYPEWRITER WITH PHOSPHOR GLOW ===
function typeCharacters(area, text) {
  charQueue.push(...text.split(''));
  if (!isTyping) drainQueue(area);
}

function drainQueue(area) {
  if (charQueue.length === 0) { isTyping = false; return; }
  isTyping = true;

  const ch = charQueue.shift();

  if (ch === '\n') {
    area.appendChild(document.createTextNode('\n'));
  } else {
    const span = document.createElement('span');
    span.className = 'phosphor-char';
    span.textContent = ch;
    area.appendChild(span);
    charsSinceSound++;
    if (charsSinceSound >= 5 + Math.floor(Math.random() * 5)) {
      playKeystroke();
      charsSinceSound = 0;
    }
  }

  chat.scrollTop = chat.scrollHeight;
  setTimeout(() => drainQueue(area), CHAR_DELAY);
}

// === LOADING ===
function showLoading() {
  const loader = document.createElement('div');
  loader.className = 'loading-bar';
  loader.innerHTML = '<span class="spinner"></span> ACCESSING ARCHIVES <span class="dots"></span>';
  chat.appendChild(loader);
  chat.scrollTop = chat.scrollHeight;

  let dotCount = 0;
  let elapsed = 0;
  const phases = [
    'ACCESSING ARCHIVES',
    'CROSS-REFERENCING KNOWLEDGE BASE',
    'COMPILING RESPONSE',
    'PROCESSING QUERY',
    'SEARCHING RECORDS'
  ];
  loader._interval = setInterval(() => {
    elapsed++;
    dotCount = (dotCount % 3) + 1;
    const phase = phases[Math.min(Math.floor(elapsed / 5), phases.length - 1)];
    const dots = '.'.repeat(dotCount);
    const secs = elapsed + 's';
    const blocks = '\u2593'.repeat(Math.min(elapsed, 40));
    loader.innerHTML = '<span class="spinner"></span> ' + phase + dots + ' [' + secs + '] ' + blocks;
  }, 1000);

  return loader;
}

function hideLoading(loader) {
  if (loader && loader._interval) clearInterval(loader._interval);
  if (loader && loader.parentNode) loader.parentNode.removeChild(loader);
}

// === MAIN SEND ===
async function send() {
  const q = input.value.trim();
  if (!q) return;
  input.value = '';
  sendBtn.disabled = true;
  input.disabled = true;

  conversationHistory.push({role: 'user', content: q});

  const userDiv = document.createElement('div');
  userDiv.className = 'msg user';
  userDiv.textContent = q;
  chat.appendChild(userDiv);
  chat.scrollTop = chat.scrollHeight;

  const loader = showLoading();

  const assistantDiv = document.createElement('div');
  assistantDiv.className = 'msg assistant';

  const prefix = document.createElement('span');
  prefix.className = 'prefix';
  prefix.textContent = 'OVERSEER>';
  assistantDiv.appendChild(prefix);

  const area = document.createElement('span');
  area.className = 'output-area cursor-blink';
  assistantDiv.appendChild(area);

  let gotFirstToken = false;
  let fullResponse = '';

  try {
    const resp = await fetch('/query', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({query: q, rag: document.getElementById('rag').checked, history: conversationHistory.slice(0, -1)})
    });
    const reader = resp.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';

    while (true) {
      const {done, value} = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, {stream: true});
      const lines = buffer.split('\n');
      buffer = lines.pop();
      for (const line of lines) {
        if (line.startsWith('data: ')) {
          try {
            const data = JSON.parse(line.slice(6));
            if (data.context !== undefined) {
              hideLoading(loader);
              chat.appendChild(assistantDiv);
              chat.scrollTop = chat.scrollHeight;
            }
            if (data.token) {
              if (!gotFirstToken) {
                gotFirstToken = true;
                hideLoading(loader);
                if (!assistantDiv.parentNode) chat.appendChild(assistantDiv);
              }
              fullResponse += data.token;
              typeCharacters(area, data.token);
            }
            if (data.done) {
              // Will remove cursor after drain
            }
            if (data.error) {
              hideLoading(loader);
              playError();
              const errDiv = document.createElement('div');
              errDiv.className = 'msg error';
              errDiv.textContent = data.error;
              chat.appendChild(errDiv);
              chat.scrollTop = chat.scrollHeight;
            }
          } catch(e) {}
        }
      }
    }
  } catch(e) {
    hideLoading(loader);
    playError();
    const errDiv = document.createElement('div');
    errDiv.className = 'msg error';
    errDiv.textContent = 'SIGNAL LOST \u2014 Server unreachable. Check hardware.';
    chat.appendChild(errDiv);
  }

  // Wait for typewriter to finish
  await new Promise(resolve => {
    const check = () => { if (!isTyping) resolve(); else setTimeout(check, 50); };
    check();
  });

  area.classList.remove('cursor-blink');
  conversationHistory.push({role: 'assistant', content: fullResponse});
  saveChat();
  sendBtn.disabled = false;
  input.disabled = false;
  input.focus();
  chat.scrollTop = chat.scrollHeight;
}

// === SPLASH & BOOT ===
// Use a separate char queue for the boot screen so it doesn't conflict with chat
let bootCharQueue = [];
let bootIsTyping = false;
let bootCharsSinceSound = 0;

function bootTypeCharacters(area, text) {
  bootCharQueue.push(...text.split(''));
  if (!bootIsTyping) bootDrainQueue(area);
}

function bootDrainQueue(area) {
  if (bootCharQueue.length === 0) { bootIsTyping = false; return; }
  bootIsTyping = true;
  const ch = bootCharQueue.shift();
  if (ch === '\n') {
    area.appendChild(document.createTextNode('\n'));
  } else {
    const span = document.createElement('span');
    span.className = 'phosphor-char';
    span.textContent = ch;
    area.appendChild(span);
    bootCharsSinceSound++;
    if (bootCharsSinceSound >= 5 + Math.floor(Math.random() * 5)) {
      playKeystroke();
      bootCharsSinceSound = 0;
    }
  }
  setTimeout(() => bootDrainQueue(area), CHAR_DELAY_FAST);
}

let bootStarted = false;
let bootFinished = false;

async function startBoot() {
  // If boot is done, enter the terminal
  if (bootFinished) {
    enterTerminal();
    return;
  }

  // Ignore clicks while booting
  if (bootStarted) return;
  bootStarted = true;

  // Show boot output, update prompt
  document.getElementById('splash-boot').style.display = '';
  document.getElementById('splash-prompt').innerHTML = '<div style="color:var(--glow-dim);font-size:0.8em;">BOOTING...</div>';

  // Init audio (user gesture from click)
  await loadKeySounds();

  // Fetch boot info
  try {
    const resp = await fetch('/boot');
    bootInfo = await resp.json();
  } catch(e) {
    bootInfo = null;
  }

  const bootArea = document.getElementById('boot-output');

  if (bootInfo) {
    const lines = [];
    lines.push('========================================');
    lines.push(' O.V.E.R.S.E.E.R.  v' + bootInfo.version);
    lines.push(' ' + bootInfo.full_name);
    lines.push('========================================');
    lines.push('');
    lines.push('BUILD DATE:    ' + bootInfo.build_date);
    lines.push('SYSTEM RAM:    ' + bootInfo.ram_total_gb + ' GB total / ' + bootInfo.ram_free_gb + ' GB free');
    lines.push('INFERENCE:     ' + bootInfo.inference_engine);
    lines.push('KB SERVER:     ' + bootInfo.knowledge_server);
    lines.push('');

    if (bootInfo.models.length > 0) {
      lines.push('--- LOADED MODELS ---');
      bootInfo.models.forEach(m => {
        lines.push('  ' + m.name + '  (' + m.size_gb + ' GB)');
      });
    } else {
      lines.push('[!] NO MODELS DETECTED');
    }
    lines.push('');

    if (bootInfo.zim_files.length > 0) {
      lines.push('--- KNOWLEDGE ARCHIVES (' + bootInfo.zim_files.length + ' volumes, ' + bootInfo.total_kb_size_gb + ' GB) ---');
      bootInfo.zim_files.forEach(z => {
        lines.push('  ' + z.name + '  [' + z.size_gb + ' GB]');
      });
    } else {
      lines.push('[!] NO KNOWLEDGE ARCHIVES FOUND');
    }

    lines.push('');
    lines.push('All systems operational.');
    lines.push('Stay sharp, operator.');

    bootTypeCharacters(bootArea, lines.join('\n'));

    await new Promise(resolve => {
      const check = () => { if (!bootIsTyping) resolve(); else setTimeout(check, 50); };
      check();
    });
  } else {
    bootArea.textContent = 'BOOT FAILED \u2014 Cannot reach server.';
  }

  bootFinished = true;
  document.getElementById('splash-prompt').innerHTML = '<div style="color:var(--glow);font-size:0.9em;animation:blink 1.2s step-end infinite;cursor:pointer;">[ CLICK TO ENTER TERMINAL ]</div>';
}

function enterTerminal() {
  document.getElementById('splash').style.display = 'none';
  document.getElementById('terminal').style.display = 'flex';

  chat = document.getElementById('chat');
  input = document.getElementById('input');
  sendBtn = document.getElementById('send');
  bindInputEvents();

  // Restore saved chat
  restoreChat();

  if (bootInfo) {
    updateStatusBar(bootInfo);
    populateSystemInfo(bootInfo);
  }

  // Start live status polling
  setInterval(pollStatus, 30000);

  // Load operators — auto-select if only one
  loadOperators();

  input.focus();
}

// === LIVE STATUS BAR ===
async function pollStatus() {
  try {
    const resp = await fetch('/status');
    const data = await resp.json();
    document.getElementById('statusRam').textContent = 'RAM: ' + data.ram_free_gb + 'GB FREE';
    document.getElementById('sysStatus').textContent = 'OPERATIONAL';
  } catch(e) {
    document.getElementById('sysStatus').textContent = 'DEGRADED';
    document.getElementById('sysStatus').style.color = 'var(--red)';
  }
}

function updateStatusBar(info) {
  document.getElementById('sysStatus').textContent = 'OPERATIONAL';
  if (info.models.length > 0) {
    const name = info.models[0].name.split(':')[0].toUpperCase();
    document.getElementById('statusModel').textContent = 'MODEL: ' + name;
  }
  document.getElementById('statusRam').textContent = 'RAM: ' + info.ram_free_gb + 'GB FREE';
  document.getElementById('statusKb').textContent = 'KB: ' + info.total_kb_size_gb + 'GB';
}

// === CLEAR CHAT ===
function clearChat() {
  if (chat) chat.innerHTML = '';
  conversationHistory.length = 0;
  localStorage.removeItem(STORAGE_KEY);
}

// === EXPORT CHAT ===
function exportChat() {
  if (conversationHistory.length === 0) return;
  const now = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
  let text = 'O.V.E.R.S.E.E.R. \u2014 Chat Export\n';
  text += 'Date: ' + new Date().toLocaleString() + '\n';
  text += '========================================\n\n';
  conversationHistory.forEach(msg => {
    const prefix = msg.role === 'user' ? 'OPERATOR> ' : 'OVERSEER>\n';
    text += prefix + msg.content + '\n\n';
  });
  const blob = new Blob([text], {type: 'text/plain'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'overseer-log-' + now + '.txt';
  a.click();
  URL.revokeObjectURL(a.href);
}

// === CHAT PERSISTENCE ===
function saveChat() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(conversationHistory));
  } catch(e) {}
}

function restoreChat() {
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;
    const history = JSON.parse(saved);
    if (!history.length) return;

    const sep = document.createElement('div');
    sep.className = 'msg assistant';
    sep.innerHTML = '<span class="prefix">OVERSEER></span><span class="output-area" style="color:var(--glow-dim);">\u2014\u2014\u2014 RESTORED SESSION (' + history.length + ' messages) \u2014\u2014\u2014</span>';
    chat.appendChild(sep);

    history.forEach(msg => {
      if (msg.role === 'user') {
        const div = document.createElement('div');
        div.className = 'msg user';
        div.textContent = msg.content;
        chat.appendChild(div);
      } else {
        const div = document.createElement('div');
        div.className = 'msg assistant';
        div.innerHTML = '<span class="prefix">OVERSEER></span><span class="output-area">' + cleanMarkdown(esc(msg.content)) + '</span>';
        chat.appendChild(div);
      }
      conversationHistory.push(msg);
    });
    chat.scrollTop = chat.scrollHeight;
  } catch(e) {}
}

// === MARKDOWN CLEANUP ===
function cleanMarkdown(text) {
  text = text.replace(/\*\*([^*]+)\*\*/g, '$1');
  text = text.replace(/```[a-z]*\n?/g, '');
  text = text.replace(/^#{1,4}\s+/gm, '');
  return text;
}

function formatArticleText(text) {
  // Escape HTML first
  let html = esc(text);
  // Convert heading markers to styled spans
  html = html.replace(/&lt;&lt;H([1-4])&gt;&gt;(.*?)&lt;&lt;\/\1&gt;&gt;/g,
    function(match, level, title) {
      return '<span class="ah ah-' + level + '">' + title + '</span>';
    });
  return html;
}

function esc(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// === SYSTEM TABS ===
function switchSystemTab(tab) {
  document.querySelectorAll('#module-system .knowledge-tabs button').forEach(b => b.classList.remove('active'));
  document.getElementById('systab-' + tab).classList.add('active');
  document.getElementById('system-status').classList.toggle('active', tab === 'status');
  document.getElementById('system-admin').classList.toggle('active', tab === 'admin');
}

// === ADMIN PIN ===
let adminPin = '';
let adminUnlocked = false;

function pinPress(n) {
  if (adminPin.length >= 8) return;
  adminPin += n;
  document.getElementById('pin-display').textContent = '\u2022'.repeat(adminPin.length);
  document.getElementById('pin-status').textContent = '';
}

function pinClear() {
  adminPin = '';
  document.getElementById('pin-display').textContent = '';
  document.getElementById('pin-status').textContent = '';
}

async function pinSubmit() {
  if (!adminPin) return;
  try {
    const resp = await fetch('/admin/verify-pin', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({pin: adminPin})
    });
    const data = await resp.json();
    if (data.ok) {
      adminUnlocked = true;
      document.getElementById('admin-pin-screen').style.display = 'none';
      document.getElementById('admin-panel').style.display = '';
      adminLoadUsers();
      adminLoadBlocks();
    } else {
      document.getElementById('pin-status').textContent = 'ACCESS DENIED';
      adminPin = '';
      document.getElementById('pin-display').textContent = '';
    }
  } catch(e) {
    document.getElementById('pin-status').textContent = 'CONNECTION ERROR';
  }
}

// === ADMIN FUNCTIONS ===
async function adminLoadUsers() {
  try {
    const resp = await fetch('/admin/users');
    const data = await resp.json();
    const container = document.getElementById('admin-user-list');
    if (data.users.length === 0) {
      container.innerHTML = '<div style="color:var(--glow-dim);padding:8px;">No operators registered. Use the form below to add one.</div>';
      return;
    }
    let html = '';
    data.users.forEach(u => {
      const date = new Date(u.created_at * 1000).toLocaleDateString();
      html += '<div class="user-card">';
      html += '<span class="callsign">' + esc(u.callsign) + '</span>';
      html += '<span class="key-preview">' + esc(u.public_key.substring(0, 40)) + '...</span>';
      html += '<span style="color:var(--glow-dim);font-size:0.7em;">' + date + '</span>';
      html += '<button class="admin-btn danger" style="padding:3px 8px;font-size:0.65em;" onclick="adminDeleteUser(' + u.id + ',\'' + esc(u.callsign) + '\')">DEL</button>';
      html += '</div>';
    });
    container.innerHTML = html;
  } catch(e) {
    document.getElementById('admin-user-list').innerHTML = '<div class="admin-msg err">Failed to load users</div>';
  }
}

async function adminRegisterUser() {
  const callsign = document.getElementById('admin-callsign').value.trim();
  const pubkey = document.getElementById('admin-pubkey').value.trim();
  const msgEl = document.getElementById('admin-register-msg');

  if (!callsign || !pubkey) {
    msgEl.className = 'admin-msg err';
    msgEl.textContent = 'Callsign and public key required';
    return;
  }

  try {
    const resp = await fetch('/admin/users', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({callsign, public_key: pubkey})
    });
    const data = await resp.json();
    if (data.ok) {
      msgEl.className = 'admin-msg ok';
      msgEl.textContent = 'Operator ' + data.callsign + ' registered';
      document.getElementById('admin-callsign').value = '';
      document.getElementById('admin-pubkey').value = '';
      adminLoadUsers();
    } else {
      msgEl.className = 'admin-msg err';
      msgEl.textContent = data.error;
    }
  } catch(e) {
    msgEl.className = 'admin-msg err';
    msgEl.textContent = 'Connection error';
  }
}

async function adminGenerateKeypair() {
  const msgEl = document.getElementById('admin-register-msg');
  try {
    const resp = await fetch('/admin/generate-keypair', {method: 'POST'});
    const data = await resp.json();

    // Put public key in the form
    document.getElementById('admin-pubkey').value = data.public_key;

    // Download private key as file
    const blob = new Blob([data.private_key], {type: 'text/plain'});
    const callsign = document.getElementById('admin-callsign').value.trim() || 'operator';
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = callsign.toLowerCase() + '_private_key.pem';
    a.click();
    URL.revokeObjectURL(a.href);

    msgEl.className = 'admin-msg ok';
    msgEl.textContent = 'Keypair generated. Private key downloaded. Public key filled in above.';
  } catch(e) {
    msgEl.className = 'admin-msg err';
    msgEl.textContent = 'Failed to generate keypair';
  }
}

async function adminDeleteUser(id, callsign) {
  if (!confirm('Remove operator ' + callsign + '? This will delete all their messages.')) return;
  try {
    await fetch('/admin/users/' + id, {method: 'DELETE'});
    adminLoadUsers();
  } catch(e) {}
}

async function adminChangePin() {
  const oldPin = document.getElementById('admin-old-pin').value;
  const newPin = document.getElementById('admin-new-pin').value;
  const msgEl = document.getElementById('admin-pin-msg');

  try {
    const resp = await fetch('/admin/change-pin', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({current: oldPin, new: newPin})
    });
    const data = await resp.json();
    if (data.ok) {
      msgEl.className = 'admin-msg ok';
      msgEl.textContent = 'PIN updated';
      document.getElementById('admin-old-pin').value = '';
      document.getElementById('admin-new-pin').value = '';
    } else {
      msgEl.className = 'admin-msg err';
      msgEl.textContent = data.error;
    }
  } catch(e) {
    msgEl.className = 'admin-msg err';
    msgEl.textContent = 'Connection error';
  }
}

async function adminLoadBlocks() {
  try {
    const resp = await fetch('/admin/blocks');
    const data = await resp.json();
    const container = document.getElementById('admin-blocks-list');
    if (data.blocks.length === 0) {
      container.innerHTML = '<div style="color:var(--glow-dim);padding:8px;">No active blocks.</div>';
      return;
    }
    let html = '';
    data.blocks.forEach(b => {
      html += '<div class="user-card">';
      html += '<span style="color:var(--glow);">' + esc(b.blocker) + '</span>';
      html += '<span style="color:var(--red);">\u2192 blocked \u2192</span>';
      html += '<span style="color:var(--glow);">' + esc(b.blocked) + '</span>';
      if (b.undelivered > 0) {
        html += '<span style="color:var(--amber);font-size:0.7em;margin-left:8px;">' + b.undelivered + ' msg dropped</span>';
      }
      html += '<button class="admin-btn" style="padding:3px 8px;font-size:0.65em;margin-left:auto;" onclick="adminUnblock(' + b.user_id + ',' + b.contact_id + ')">UNBLOCK</button>';
      html += '</div>';
    });
    container.innerHTML = html;
  } catch(e) {
    document.getElementById('admin-blocks-list').innerHTML = '<div class="admin-msg err">Failed to load blocks</div>';
  }
}

async function adminUnblock(userId, contactId) {
  try {
    await fetch('/admin/unblock', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({user_id: userId, contact_id: contactId})
    });
    adminLoadBlocks();
  } catch(e) {}
}

// ============================================================
// GLOBAL OPERATOR SYSTEM
// ============================================================

let activeUserId = null;
let activeCallsign = '';
let allUsers = [];

async function loadOperators() {
  try {
    const resp = await fetch('/comms/users');
    const data = await resp.json();
    allUsers = data.users || [];
    if (allUsers.length === 1) {
      // Auto-select the only operator
      setActiveOperator(allUsers[0].id, allUsers[0].callsign);
    } else if (allUsers.length > 1) {
      document.getElementById('header-op-name').textContent = '[SELECT]';
    } else {
      document.getElementById('header-op-name').textContent = 'NONE';
    }
  } catch(e) {
    document.getElementById('header-op-name').textContent = 'OFFLINE';
  }
}

function setActiveOperator(userId, callsign) {
  activeUserId = userId;
  activeCallsign = callsign;
  document.getElementById('header-op-name').textContent = callsign;
  document.getElementById('comms-identity').textContent = callsign;
  document.getElementById('rec-identity').textContent = callsign;
  // Close picker
  document.getElementById('op-picker').classList.remove('active');
  // Start comms refresh
  if (commsRefreshTimer) clearInterval(commsRefreshTimer);
  commsRefreshTimer = setInterval(() => {
    if (commsCurrentContact) commsLoadThread(commsCurrentContact.id, commsCurrentContact.callsign, true);
  }, 5000);
}

function toggleOperatorPicker() {
  const picker = document.getElementById('op-picker');
  if (picker.classList.contains('active')) {
    picker.classList.remove('active');
    return;
  }
  let html = '';
  allUsers.forEach(u => {
    const isCurrent = u.id === activeUserId;
    html += '<div class="op-picker-item' + (isCurrent ? ' current' : '') + '" onclick="setActiveOperator(' + u.id + ',\'' + esc(u.callsign).replace(/'/g, "\\'") + '\')">' + esc(u.callsign) + '</div>';
  });
  if (!html) html = '<div class="op-picker-item" style="color:var(--glow-dim);">No operators registered</div>';
  picker.innerHTML = html;
  picker.classList.add('active');
}

// Close picker when clicking elsewhere
document.addEventListener('click', function(e) {
  if (!e.target.closest('.op-picker') && !e.target.closest('.op-name') && !e.target.closest('.op-switch')) {
    document.getElementById('op-picker').classList.remove('active');
  }
});

// === COMMS ===
let commsCurrentContact = null;
let commsRefreshTimer = null;

// Alias for backward compat — modules read activeUserId
Object.defineProperty(window, 'commsUserId', { get() { return activeUserId; } });
Object.defineProperty(window, 'commsCallsign', { get() { return activeCallsign; } });
Object.defineProperty(window, 'recUserId', { get() { return activeUserId; } });
Object.defineProperty(window, 'recCallsign', { get() { return activeCallsign; } });

function formatTime(ts) {
  const d = new Date(ts * 1000);
  const pad = n => String(n).padStart(2, '0');
  const now = new Date();
  const isToday = d.toDateString() === now.toDateString();
  if (isToday) return pad(d.getHours()) + ':' + pad(d.getMinutes());
  return pad(d.getDate()) + '/' + pad(d.getMonth()+1) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
}

function deliveryIcon(status) {
  switch(status) {
    case 'queued': return '<span class="delivery-tick queued" title="Queued">&#9675;</span>';    // ○
    case 'sent': return '<span class="delivery-tick sent" title="Sent">&#10003;</span>';         // ✓
    case 'delivered': return '<span class="delivery-tick delivered" title="Delivered">&#10003;&#10003;</span>'; // ✓✓
    case 'read': return '<span class="delivery-tick read" title="Read">&#10003;&#10003;</span>'; // ✓✓ bright
    default: return '';
  }
}

// === CONVERSATION LIST ===

function commsShowConversations() {
  commsCurrentContact = null;
  document.getElementById('comms-conversations').style.display = 'flex';
  document.getElementById('comms-thread').classList.remove('active');
  document.getElementById('comms-new-msg').classList.remove('active');
  commsLoadConversations();
}

async function commsLoadConversations() {
  if (!commsUserId) return;
  const container = document.getElementById('comms-conv-list');
  try {
    const resp = await fetch('/comms/conversations/' + commsUserId);
    const data = await resp.json();
    if (data.conversations.length === 0) {
      container.innerHTML = '<div class="comms-empty">No conversations yet.<br>Tap + NEW to start one.</div>';
      return;
    }
    let html = '';
    data.conversations.forEach(c => {
      const isPending = c.contact_status === 'pending' || c.contact_status === 'none';
      const isOverseer = c.callsign === 'OVERSEER';
      let cls = '';
      if (isPending && !isOverseer) cls = ' pending';
      // Preview: truncate last message
      let preview = c.last_message || '';
      if (preview.length > 50) preview = preview.substring(0, 50) + '...';
      const isSent = c.last_message_from == commsUserId;
      if (isSent && preview) preview = 'You: ' + preview;

      html += '<div class="conv-item' + cls + '" onclick="commsOpenThread(' + c.other_id + ',\'' + esc(c.callsign).replace(/'/g, "\\'") + '\')">';
      html += '<div class="conv-info">';
      html += '<div class="conv-callsign">' + esc(c.callsign);
      if (isPending && !isOverseer) html += '<span class="conv-status-label conv-status-pending">NEW</span>';
      html += '</div>';
      html += '<div class="conv-preview">' + esc(preview) + '</div>';
      html += '</div>';
      html += '<div class="conv-meta">';
      if (c.last_message_at) html += '<div class="conv-time">' + formatTime(c.last_message_at) + '</div>';
      if (c.unread_count > 0) html += '<div class="conv-badge">' + c.unread_count + '</div>';
      html += '</div>';
      html += '</div>';
    });
    container.innerHTML = html;
  } catch(e) {
    container.innerHTML = '<div class="comms-empty">Connection error</div>';
  }
}

// === CHAT THREAD ===

function commsOpenThread(contactId, callsign) {
  commsLoadThread(contactId, callsign, false);
}

async function commsLoadThread(contactId, callsign, isRefresh) {
  if (!commsUserId) return;

  // Show thread view
  document.getElementById('comms-conversations').style.display = 'none';
  document.getElementById('comms-new-msg').classList.remove('active');
  document.getElementById('comms-thread').classList.add('active');

  try {
    const resp = await fetch('/comms/thread/' + commsUserId + '/' + contactId);
    const data = await resp.json();

    commsCurrentContact = data.contact;
    document.getElementById('thread-contact-name').textContent = data.contact.callsign;

    // Thread actions (accept/block for non-OVERSEER contacts)
    const actions = document.getElementById('thread-actions');
    const status = data.contact.status;
    const isOverseer = data.contact.callsign === 'OVERSEER';
    let btns = '';
    if ((status === 'pending' || status === 'none') && !isOverseer) {
      btns += '<button class="thread-accept" onclick="commsAcceptContact(' + contactId + ')">ACCEPT</button>';
      btns += '<button class="thread-block" onclick="commsBlockContact(' + contactId + ')">BLOCK</button>';
    } else if (status === 'accepted' && !isOverseer) {
      btns += '<button class="thread-block" onclick="commsBlockContact(' + contactId + ')">BLOCK</button>';
    }
    actions.innerHTML = btns;

    // Render messages as chat bubbles
    const container = document.getElementById('comms-messages');
    let html = '';
    data.messages.forEach(m => {
      const isSent = m.from_user == commsUserId;
      const cls = isSent ? 'sent' : 'received';
      html += '<div class="chat-bubble ' + cls + '">';
      html += esc(m.body);
      html += '<div class="chat-meta">';
      html += '<span>' + formatTime(m.sent_at) + '</span>';
      if (isSent && m.delivery_status) html += deliveryIcon(m.delivery_status);
      if (m.source === 'lora') html += '<span title="Via LoRa">&#x1F4E1;</span>';
      html += '</div>';
      html += '</div>';
    });

    if (data.messages.length === 0) {
      html = '<div class="comms-empty" style="padding:20px;">No messages yet. Say something.</div>';
    }

    container.innerHTML = html;

    // Auto-scroll to bottom (skip on refresh if user scrolled up)
    if (!isRefresh || container.scrollHeight - container.scrollTop - container.clientHeight < 100) {
      container.scrollTop = container.scrollHeight;
    }

    // Mark unread messages as read
    data.messages.forEach(m => {
      if (m.from_user != commsUserId && !m.read_at) {
        fetch('/comms/read/' + m.id, {method: 'POST'});
      }
    });

    // Focus input
    if (!isRefresh) document.getElementById('chat-input').focus();

  } catch(e) {
    document.getElementById('comms-messages').innerHTML = '<div class="comms-empty">Connection error</div>';
  }
}

function commsBackToList() {
  commsCurrentContact = null;
  document.getElementById('comms-thread').classList.remove('active');
  document.getElementById('comms-new-msg').classList.remove('active');
  document.getElementById('comms-conversations').style.display = 'flex';
  commsLoadConversations();
}

// === SEND MESSAGE ===

async function commsSend() {
  if (!commsCurrentContact) return;
  const input = document.getElementById('chat-input');
  const body = input.value.trim();
  if (!body) return;

  try {
    const resp = await fetch('/comms/send', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({from: commsUserId, to: commsCurrentContact.id, body: body})
    });
    const data = await resp.json();
    if (data.ok) {
      input.value = '';
      chatInputResize(input);
      chatUpdateCharCount();
      commsLoadThread(commsCurrentContact.id, commsCurrentContact.callsign, false);
    }
  } catch(e) {}
}

// === NEW MESSAGE ===

async function commsShowNewMsg() {
  document.getElementById('comms-conversations').style.display = 'none';
  document.getElementById('comms-thread').classList.remove('active');
  document.getElementById('comms-new-msg').classList.add('active');

  try {
    const resp = await fetch('/comms/users?viewer=' + commsUserId);
    const data = await resp.json();
    const container = document.getElementById('comms-new-msg-list');
    let html = '';
    data.users.forEach(u => {
      if (u.id !== commsUserId && !u.blocked) {
        html += '<div class="conv-item" onclick="commsOpenThread(' + u.id + ',\'' + esc(u.callsign).replace(/'/g, "\\'") + '\')">';
        html += '<div class="conv-info"><div class="conv-callsign">' + esc(u.callsign) + '</div></div>';
        html += '</div>';
      }
    });
    if (!html) html = '<div class="comms-empty">No operators available.</div>';
    container.innerHTML = html;
  } catch(e) {
    document.getElementById('comms-new-msg-list').innerHTML = '<div class="comms-empty">Connection error</div>';
  }
}

// === INPUT HELPERS ===

function chatInputResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function chatUpdateCharCount() {
  const input = document.getElementById('chat-input');
  const count = new TextEncoder().encode(input.value).length;
  const el = document.getElementById('chat-char-count');
  el.textContent = count + 'B';
  el.className = 'char-count' + (count > 180 ? ' over' : count > 150 ? ' warn' : '');
}

// === CONTACT TRUST SYSTEM ===
async function commsAcceptContact(contactId) {
  try {
    await fetch('/comms/contacts/accept', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({user_id: commsUserId, contact_id: contactId})
    });
    if (commsCurrentContact) commsLoadThread(commsCurrentContact.id, commsCurrentContact.callsign, false);
    else commsLoadConversations();
  } catch(e) {}
}

async function commsBlockContact(contactId) {
  try {
    await fetch('/comms/contacts/block', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({user_id: commsUserId, contact_id: contactId})
    });
    commsBackToList();
  } catch(e) {}
}

// ============================================================
// RECREATION MODULE
// ============================================================

let recCurrentCat = null;
let recEngine = null;  // loaded game engine

// === SYNC MANAGER ===

async function recShowSync() {
  const browser = document.getElementById('rec-browser');
  browser.innerHTML = '<div class="rec-section-title">SYNC MANAGER</div><div style="padding:12px;color:var(--glow-dim);font-size:0.75em;">Checking for updates...</div>';
  document.getElementById('rec-browser').style.display = 'block';
  document.getElementById('rec-gamelist').style.display = 'none';
  document.getElementById('rec-play').classList.remove('active');

  try {
    const resp = await fetch('/games/catalog');
    const catalog = await resp.json();

    // Check local cache versions
    const cachedEngineVer = parseInt(localStorage.getItem('games_engine_ver') || '0');
    const engineNeedsUpdate = catalog.engine_version > cachedEngineVer;

    let updates = [];
    if (engineNeedsUpdate) {
      updates.push({
        id: '_engine',
        name: 'Game Engine v' + catalog.engine_version,
        size: catalog.engine_compressed,
        type: 'engine'
      });
    }

    catalog.games.forEach(g => {
      const cachedVer = parseInt(localStorage.getItem('games_dataver_' + g.id) || '0');
      if (g.version > cachedVer) {
        updates.push({
          id: g.id,
          name: g.name + ' v' + g.version,
          size: g.compressed_size,
          type: 'data',
          category: g.category
        });
      }
    });

    // Also sync stats from server
    let serverStats = {};
    try {
      const sr = await fetch('/games/stats/' + recUserId);
      const sd = await sr.json();
      serverStats = sd.stats || {};
      // Merge: server wins if no local version
      Object.keys(serverStats).forEach(gameId => {
        const localKey = 'games_state_' + recUserId + '_' + gameId;
        if (!localStorage.getItem(localKey)) {
          localStorage.setItem(localKey, JSON.stringify(serverStats[gameId]));
        }
      });
    } catch(e) {}

    let html = '<div class="rec-section-title">SYNC MANAGER</div>';

    // Show synced items
    html += '<div style="padding:4px 0;font-size:0.65em;color:var(--glow-dim);border-bottom:1px solid var(--border);margin-bottom:8px;">';
    html += 'Game state .............. synced<br>';
    html += 'Chat history ............ synced</div>';

    if (updates.length === 0) {
      html += '<div style="padding:12px 0;font-size:0.75em;color:var(--glow);">All games up to date.</div>';
      html += '<div class="game-btn-row"><button class="game-btn" onclick="recShowCategories()">PLAY GAMES</button></div>';
    } else {
      html += '<div style="font-size:0.7em;color:var(--glow-dim);margin:8px 0;">AVAILABLE UPDATES:</div>';
      updates.forEach((u, i) => {
        const sizeKB = (u.size / 1024).toFixed(1);
        const estSec = Math.ceil(u.size / 500); // rough estimate
        html += '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;font-size:0.7em;">';
        html += '<input type="checkbox" id="sync-cb-' + i + '" checked data-idx="' + i + '">';
        html += '<label for="sync-cb-' + i + '" style="flex:1;color:var(--glow);">' + esc(u.name) + '</label>';
        html += '<span style="color:var(--glow-dim);">' + sizeKB + 'KB ~' + estSec + 's</span>';
        html += '</div>';
      });

      const totalSize = updates.reduce((s, u) => s + u.size, 0);
      const totalKB = (totalSize / 1024).toFixed(1);
      const totalSec = Math.ceil(totalSize / 500);

      html += '<div style="font-size:0.65em;color:var(--glow-dim);margin-top:8px;padding-top:4px;border-top:1px solid var(--border);">';
      html += 'Total selected: ' + totalKB + 'KB (~' + totalSec + 's)</div>';
      html += '<div class="game-btn-row" style="margin-top:8px;">';
      html += '<button class="game-btn" onclick="recSyncSelected()">SYNC NOW</button>';
      html += '<button class="game-btn" onclick="recShowCategories()">SKIP</button>';
      html += '</div>';
      html += '<div id="rec-sync-progress"></div>';
    }

    // Store updates list for sync
    window._recUpdates = updates;
    browser.innerHTML = html;

    // Auto-show categories if nothing to update and engine is cached
    if (updates.length === 0 && localStorage.getItem('games_engine')) {
      recLoadEngine();
      recShowCategories();
    }

  } catch(e) {
    browser.innerHTML = '<div class="rec-section-title">SYNC MANAGER</div>' +
      '<div style="padding:12px;color:var(--glow-dim);font-size:0.75em;">Cannot reach OVERSEER base.<br>Using cached games.</div>' +
      '<div class="game-btn-row"><button class="game-btn" onclick="recShowCategories()">PLAY CACHED GAMES</button></div>';
    recLoadEngine();
  }
}

async function recSyncSelected() {
  const updates = window._recUpdates || [];
  const progress = document.getElementById('rec-sync-progress');
  let synced = 0;

  for (let i = 0; i < updates.length; i++) {
    const cb = document.getElementById('sync-cb-' + i);
    if (!cb || !cb.checked) continue;

    const u = updates[i];
    progress.innerHTML = '<div style="font-size:0.65em;color:var(--glow);margin-top:8px;">Syncing: ' + esc(u.name) + '...</div>';

    try {
      if (u.type === 'engine') {
        const resp = await fetch('/games/engine');
        const js = await resp.text();
        localStorage.setItem('games_engine', js);
        localStorage.setItem('games_engine_ver', resp.headers.get('X-Engine-Version') || '1');
      } else {
        const resp = await fetch('/games/data/' + u.id);
        const data = await resp.text();
        localStorage.setItem('games_data_' + u.id, data);
        localStorage.setItem('games_dataver_' + u.id, String(updates[i].version || 1));
      }
      synced++;
    } catch(e) {
      progress.innerHTML = '<div style="font-size:0.65em;color:var(--red);margin-top:8px;">Failed: ' + esc(u.name) + '</div>';
    }
  }

  progress.innerHTML = '<div style="font-size:0.65em;color:var(--glow-bright);margin-top:8px;">Synced ' + synced + ' items.</div>';
  recLoadEngine();
  setTimeout(recShowCategories, 1000);
}

// === ENGINE LOADER ===

function recLoadEngine() {
  const js = localStorage.getItem('games_engine');
  if (!js) return false;
  try {
    // Execute the engine code (only once)
    if (!window.GAMES) {
      // Handle both old (const GAMES) and new (window.GAMES) cached versions
      const safeJs = js.replace(/^const GAMES\s*=/, 'window.GAMES =');
      new Function(safeJs)();
    }
    recEngine = window.GAMES;

    // Wire up stat sync to server
    window._gameSyncStat = function(userId, gameId, stats) {
      // Non-blocking server sync
      Object.keys(stats).forEach(key => {
        fetch('/games/stats', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({user_id: userId, game_id: gameId, key: key, value: String(stats[key])})
        }).catch(() => {});
      });
    };
    return true;
  } catch(e) {
    console.error('Engine load failed:', e);
    return false;
  }
}

// === CATEGORY BROWSER ===

function recShowCategories() {
  if (!recEngine && !recLoadEngine()) {
    document.getElementById('rec-browser').innerHTML =
      '<div class="rec-section-title">GAME CATEGORIES</div>' +
      '<div class="comms-empty">No games cached. Sync with OVERSEER base first.</div>' +
      '<div class="game-btn-row"><button class="game-btn" onclick="recShowSync()">SYNC</button></div>';
    document.getElementById('rec-browser').style.display = 'block';
    document.getElementById('rec-gamelist').style.display = 'none';
    document.getElementById('rec-play').classList.remove('active');
    return;
  }

  document.getElementById('rec-browser').style.display = 'block';
  document.getElementById('rec-gamelist').style.display = 'none';
  document.getElementById('rec-play').classList.remove('active');

  const cats = recEngine.categories;
  let html = '<div class="rec-section-title">GAME CATEGORIES</div><div class="rec-cat-grid">';

  cats.forEach(cat => {
    const count = recEngine.catalog.filter(g => g.cat === cat.id).length;
    html += '<div class="rec-cat-btn" onclick="recShowGameList(\'' + cat.id + '\')">';
    html += '<span class="cat-icon">' + cat.icon + '</span>';
    html += '<span class="cat-name">' + cat.name + '</span>';
    html += '<span class="cat-count">' + count + ' game' + (count !== 1 ? 's' : '') + '</span>';
    html += '</div>';
  });

  html += '</div>';
  html += '<div style="margin-top:12px;text-align:center;"><button class="game-btn" style="font-size:0.6em;" onclick="recShowSync()">CHECK FOR UPDATES</button></div>';

  document.getElementById('rec-browser').innerHTML = html;
}

// === GAME LIST ===

function recShowGameList(catId) {
  recCurrentCat = catId;
  document.getElementById('rec-browser').style.display = 'none';
  document.getElementById('rec-gamelist').style.display = 'flex';
  document.getElementById('rec-play').classList.remove('active');

  const cat = recEngine.categories.find(c => c.id === catId);
  document.getElementById('rec-cat-title').textContent = cat ? cat.name : catId.toUpperCase();

  const games = recEngine.catalog.filter(g => g.cat === catId);
  const list = document.getElementById('rec-game-list');
  let html = '';

  games.forEach(g => {
    const stats = recEngine.getStats(recUserId, g.id);
    const played = stats.played || stats.total_rounds || 0;
    html += '<div class="rec-game-item" onclick="recLaunchGame(\'' + g.id + '\')">';
    html += '<div><div class="rec-game-title">' + esc(g.name) + '</div>';
    html += '<div class="rec-game-desc">' + esc(g.desc) + '</div></div>';
    if (parseInt(played) > 0) {
      html += '<div class="rec-game-stat">';
      if (stats.wins) html += '<div class="stat-label">W: ' + stats.wins + '</div>';
      if (stats.high_score) html += '<div class="stat-label">HI: ' + stats.high_score + '</div>';
      html += '<div class="stat-value">' + played + ' played</div>';
      html += '</div>';
    }
    html += '</div>';
  });

  if (!html) html = '<div class="comms-empty">No games in this category.</div>';
  list.innerHTML = html;
}

// === GAME LAUNCH ===

function recLaunchGame(gameId) {
  document.getElementById('rec-browser').style.display = 'none';
  document.getElementById('rec-gamelist').style.display = 'none';
  document.getElementById('rec-play').classList.add('active');

  const game = recEngine.catalog.find(g => g.id === gameId);
  document.getElementById('rec-play-title').textContent = game ? game.name : gameId;

  // Show difficulty picker for games that support it
  const hasDifficulty = ['hangman', 'codebreaker', 'numberhunt', 'tictactoe', 'morse'].includes(gameId);
  const area = document.getElementById('rec-play-area');

  if (hasDifficulty) {
    const diffs = gameId === 'morse'
      ? [['beginner','BEGINNER'],['intermediate','INTERMEDIATE'],['advanced','ADVANCED']]
      : [['easy','EASY'],['medium','MEDIUM'],['hard','HARD']];

    let html = '<div style="margin-top:20px;text-align:center;">';
    html += '<div style="font-size:0.7em;color:var(--glow-dim);letter-spacing:2px;margin-bottom:12px;">SELECT DIFFICULTY</div>';
    html += '<div class="game-btn-row">';
    diffs.forEach(([val, label]) => {
      html += '<button class="game-btn" onclick="recStartGame(\'' + gameId + '\',\'' + val + '\')">' + label + '</button>';
    });
    html += '</div></div>';
    area.innerHTML = html;
  } else {
    recStartGame(gameId);
  }

  // Update stats display
  const stats = recEngine.getStats(recUserId, gameId);
  let statText = '';
  if (stats.played) statText += 'Played: ' + stats.played;
  if (stats.wins) statText += ' | W: ' + stats.wins;
  if (stats.losses) statText += ' | L: ' + stats.losses;
  document.getElementById('rec-play-stats').textContent = statText;
}

function recStartGame(gameId, difficulty) {
  const area = document.getElementById('rec-play-area');
  recEngine.launch(gameId, area, recUserId, difficulty);
}

function recExitGame() {
  document.getElementById('rec-play').classList.remove('active');
  if (recCurrentCat) {
    recShowGameList(recCurrentCat);
  } else {
    recShowCategories();
  }
}
</script>
</body>
</html>
